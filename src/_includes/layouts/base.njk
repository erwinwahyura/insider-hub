<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5">
  <meta name="theme-color" content="#1a6e3c">
  <meta name="description" content="Insider Hub - Indonesia Market Intelligence">
  
  <!-- Auto-refresh: 5 min during market hours -->
  <meta http-equiv="refresh" content="300" id="auto-refresh">
  <script>
    (function() {
      const now = new Date();
      const wibHour = (now.getUTCHours() + 7) % 24;
      const wibDay = now.getUTCDay();
      const isWeekday = wibDay >= 1 && wibDay <= 5;
      const isMarketHours = (wibHour >= 9 && wibHour < 12) || (wibHour >= 13 && wibHour < 16);
      
      if (!isWeekday || !isMarketHours) {
        document.getElementById('auto-refresh').content = '1800'; // 30 min when closed
      }
    })();
  </script>
  
  <title>{{ title }} — Insider Hub</title>
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  
  <style>
    :root {
      --bg: #f8fafc;
      --bg-raised: #ffffff;
      --bg-subtle: #f1f5f9;
      --border: #e2e8f0;
      --text: #0f172a;
      --text-2: #475569;
      --text-3: #94a3b8;
      --up: #059669;
      --up-bg: #d1fae5;
      --down: #dc2626;
      --down-bg: #fee2e2;
      --amber: #d97706;
      --accent: #3b82f6;
      --shadow: 0 1px 3px 0 rgba(0,0,0,0.1);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1);
      --sans: system-ui, -apple-system, sans-serif;
      --mono: 'SF Mono', 'Courier New', monospace;
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.5;
    }
    
    a { color: inherit; text-decoration: none; }
    
    .topbar {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.5rem 1rem;
      height: auto;
      min-height: 48px;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: var(--bg);
      z-index: 10;
    }
    
    .topbar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      max-width: 860px;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    
    .topbar-left {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    
    .logo {
      font-size: 16px;
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    
    .logo-sub {
      font-size: 12px;
      color: var(--text-3);
      display: none;
    }
    
    @media (min-width: 640px) {
      .logo-sub { display: inline; }
    }
    
    .private-badge {
      font-size: 10px;
      font-weight: 500;
      color: var(--text-3);
      border: 1px solid var(--border);
      padding: 1px 6px;
      border-radius: 3px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    
    .mobile-menu-btn {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      width: 44px;
      height: 44px;
      min-width: 44px;
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: pointer;
      padding: 8px;
      gap: 4px;
      margin-left: auto;
      -webkit-tap-highlight-color: transparent;
    }
    
    @media (min-width: 768px) {
      .mobile-menu-btn { display: none; }
    }
    
    .mobile-menu-btn span {
      display: block;
      width: 18px;
      height: 2px;
      background: var(--text-2);
      border-radius: 1px;
      transition: all 0.2s ease;
    }
    
    .mobile-menu-btn.open span:nth-child(1) { transform: rotate(45deg) translate(4px, 4px); }
    .mobile-menu-btn.open span:nth-child(2) { opacity: 0; }
    .mobile-menu-btn.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }
    
    .topbar-nav {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 0.5rem;
      padding: 0.75rem 0;
      margin-top: 0.5rem;
      border-top: 1px solid var(--border);
    }
    
    .topbar-nav.open { display: flex; }
    
    @media (min-width: 768px) {
      .topbar-nav {
        display: flex !important;
        flex-direction: row;
        width: auto;
        margin: 0;
        padding: 0;
        border: none;
        gap: 1rem;
      }
    }
    
    .nav-link {
      display: block;
      font-size: 14px;
      color: var(--text-3);
      padding: 0.625rem 0.75rem;
      border: 1px solid var(--border);
      border-radius: 4px;
      transition: all 0.15s;
    }
    
    @media (min-width: 768px) {
      .nav-link {
        font-size: 12px;
        padding: 2px 8px;
      }
    }
    
    .nav-link:hover, .nav-link.active {
      color: var(--text);
      border-color: var(--up);
      background: var(--up-bg);
    }
    
    .body {
      flex: 1;
      padding: 0.75rem;
      max-width: 860px;
      margin: 0 auto;
      width: 100%;
    }
    
    @media (min-width: 768px) {
      .body { padding: 1.25rem 1.5rem; }
    }
    
    .page { min-height: 100vh; display: flex; flex-direction: column; }
    
    .footer {
      padding: 1rem 1.5rem;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: 12px;
      color: var(--text-3);
      background: var(--bg-subtle);
    }
    
    .card {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
      box-shadow: var(--shadow);
    }
    
    .panel {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
      box-shadow: var(--shadow);
    }
    
    .panel-head {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding-bottom: 0.625rem;
      margin-bottom: 0.625rem;
      border-bottom: 1px solid var(--border);
    }
    
    .panel-title {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    
    .up { color: var(--up); }
    .down { color: var(--down); }
    .amber { color: var(--amber); }
    .dim { color: var(--text-3); font-size: 12px; }
    .mono { font-family: var(--mono); }
    
    h1 { font-size: 24px; font-weight: 600; margin-bottom: 0.5rem; }
    h2 { font-size: 14px; font-weight: 600; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; }
    
    .stats-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 1rem;
    }
    
    @media (min-width: 640px) {
      .stats-row { grid-template-columns: repeat(3, 1fr); }
    }
    
    @media (min-width: 768px) {
      .stats-row { grid-template-columns: repeat(5, 1fr); }
    }
    
    .stat {
      background: var(--bg-raised);
      padding: 0.75rem 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      min-height: 60px;
      justify-content: center;
    }
    
    .stat-n { font-size: 20px; font-weight: 600; line-height: 1; }
    .stat-l { font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; }
    
    .commodities {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    
    @media (min-width: 768px) {
      .commodities { grid-template-columns: repeat(5, 1fr); }
    }
    
    .commodity {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.75rem;
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      min-height: 60px;
      border-left: 3px solid transparent;
    }
    
    .commodity:hover { box-shadow: var(--shadow-md); }
    .commodity.up { border-left-color: var(--up); background: linear-gradient(135deg, var(--bg-raised) 0%, var(--up-bg) 100%); }
    .commodity.down { border-left-color: var(--down); background: linear-gradient(135deg, var(--bg-raised) 0%, var(--down-bg) 100%); }
    
    .comm-name { font-size: 14px; font-weight: 600; }
    .comm-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem; }
    .comm-price { font-size: 14px; font-weight: 600; }
    .comm-delta { font-size: 12px; }
    
    .news-list { display: flex; flex-direction: column; gap: 0.75rem; }
    
    .news-card {
      display: flex;
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.875rem;
      text-decoration: none;
      transition: all 0.12s;
    }
    
    .news-card:hover { background: var(--bg-subtle); }
    .news-bar { width: 3px; flex-shrink: 0; border-radius: 1px; margin-right: 0.75rem; }
    .news-bar.up { background: var(--up); }
    .news-bar.down { background: var(--down); }
    .news-bar.neutral { background: var(--border); }
    
    .news-content { flex: 1; min-width: 0; }
    .news-meta { display: flex; flex-wrap: wrap; gap: 0.5rem; font-size: 11px; color: var(--text-3); margin-bottom: 0.3rem; }
    .news-title { font-size: 14px; font-weight: 500; color: var(--text); line-height: 1.4; margin-bottom: 0.25rem; }
    .news-body { font-size: 13px; color: var(--text-2); line-height: 1.4; }
    .news-chips { display: flex; gap: 0.25rem; flex-wrap: wrap; margin-top: 0.5rem; }
    
    .chip {
      font-size: 10px;
      font-family: var(--mono);
      background: var(--up-bg);
      color: var(--up);
      border: 1px solid rgba(26,110,60,0.18);
      padding: 1px 6px;
      border-radius: 2px;
    }
    
    .badge {
      font-size: 10px;
      font-weight: 600;
      padding: 1px 6px;
      border-radius: 2px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    
    .badge-neutral { color: var(--text-2); background: var(--bg-subtle); border: 1px solid var(--border); }
    .badge-up { color: var(--up); background: var(--up-bg); }
    .badge-down { color: var(--down); background: var(--down-bg); }
    
    .impact-tag { font-size: 10px; font-weight: 600; }
    .impact-tag.up { color: var(--up); }
    .impact-tag.down { color: var(--down); }
    .impact-tag.neutral { color: var(--text-3); }
    
    /* Smart Money Summary */
    .smart-money-summary {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
      box-shadow: var(--shadow);
    }
    .sm-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    .sm-title { font-weight: 600; font-size: 14px; }
    .sm-time { font-size: 12px; color: var(--text-3); }
    .sm-stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }
    .sm-stat {
      text-align: center;
      padding: 0.5rem;
      background: var(--bg-subtle);
      border-radius: 6px;
    }
    .sm-stat.buy { background: var(--up-bg); }
    .sm-stat.sell { background: var(--down-bg); }
    .sm-num {
      display: block;
      font-size: 20px;
      font-weight: 700;
      font-family: var(--mono);
    }
    .sm-stat.buy .sm-num { color: var(--up); }
    .sm-stat.sell .sm-num { color: var(--down); }
    .sm-label {
      font-size: 11px;
      color: var(--text-2);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .sm-signals {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .sm-signal {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.5rem 0.75rem;
      background: var(--bg-subtle);
      border-radius: 6px;
      font-size: 13px;
    }
    .sm-signal.bullish {
      border-left: 3px solid var(--up);
      background: var(--up-bg);
    }
    .sm-signal.bearish {
      border-left: 3px solid var(--down);
      background: var(--down-bg);
    }
    .sm-ticker {
      font-weight: 600;
      font-family: var(--mono);
      min-width: 50px;
    }
    .sm-pattern { flex: 1; color: var(--text-2); }
    .sm-conf {
      font-size: 11px;
      padding: 2px 6px;
      border-radius: 4px;
      background: var(--bg-raised);
    }
    .sm-conf.high { background: var(--up); color: white; }
    .sm-conf.medium { background: var(--amber); color: white; }
    
    /* Foreign Flow */
    .foreign-flow {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
      box-shadow: var(--shadow);
    }
    .ff-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    .ff-title { font-weight: 600; font-size: 14px; }
    .ff-net {
      font-weight: 700;
      font-family: var(--mono);
      font-size: 16px;
    }
    .ff-bars {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .ff-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 13px;
    }
    .ff-ticker {
      font-family: var(--mono);
      font-weight: 600;
      min-width: 50px;
    }
    .ff-bar-wrap {
      flex: 1;
      height: 20px;
      background: var(--bg-subtle);
      border-radius: 4px;
      overflow: hidden;
    }
    .ff-bar {
      height: 100%;
      border-radius: 4px;
      transition: width 0.3s ease;
    }
    .ff-bar.buy { background: var(--up); }
    .ff-bar.sell { background: var(--down); }
    .ff-val {
      font-family: var(--mono);
      font-weight: 600;
      min-width: 60px;
      text-align: right;
      font-size: 12px;
    }
    
    /* Block Trades */
    .block-trades {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
      box-shadow: var(--shadow);
    }
    .bt-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    .bt-title { font-weight: 600; font-size: 14px; }
    .bt-total {
      font-weight: 700;
      font-family: var(--mono);
      font-size: 14px;
      color: var(--text-2);
    }
    .bt-trade {
      padding: 0.75rem;
      background: var(--bg-subtle);
      border-radius: 6px;
      margin-bottom: 0.5rem;
      border-left: 3px solid var(--text-3);
    }
    .bt-trade.buy {
      border-left-color: var(--up);
      background: var(--up-bg);
    }
    .bt-trade.sell {
      border-left-color: var(--down);
      background: var(--down-bg);
    }
    .bt-main {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.25rem;
      flex-wrap: wrap;
    }
    .bt-ticker {
      font-weight: 600;
      font-family: var(--mono);
    }
    .bt-type {
      font-size: 11px;
      padding: 2px 6px;
      border-radius: 4px;
      background: var(--bg-raised);
      font-weight: 600;
    }
    .bt-trade.buy .bt-type { background: var(--up); color: white; }
    .bt-trade.sell .bt-type { background: var(--down); color: white; }
    .bt-val { font-family: var(--mono); font-weight: 700; }
    .bt-party {
      font-size: 11px;
      color: var(--text-2);
      background: var(--bg-raised);
      padding: 2px 6px;
      border-radius: 4px;
    }
    .bt-note { font-size: 12px; color: var(--text-2); line-height: 1.4; }
  </style>
</head>
<body>
  <div class="page">
    {% include "nav.njk" %}
    
    <div class="body">
      {{ content | safe }}
    </div>
    
    <footer class="footer">
      Insider Hub · Built by Elesis · Live prices {{ stocks.timestamp | dateFormat }}
    </footer>
  </div>
  
  <script>
    // Mobile menu toggle
    const menuBtn = document.getElementById('menuBtn');
    const mainNav = document.getElementById('mainNav');
    if (menuBtn && mainNav) {
      menuBtn.addEventListener('click', function() {
        menuBtn.classList.toggle('open');
        mainNav.classList.toggle('open');
      });
      mainNav.querySelectorAll('.nav-link').forEach(function(link) {
        link.addEventListener('click', function() {
          menuBtn.classList.remove('open');
          mainNav.classList.remove('open');
        });
      });
    }
  </script>
</body>
</html>
