<header class="topbar">
  <div class="topbar-inner">
    <div class="topbar-left">
      <a href="/" class="logo">Insider Hub</a>
      <span class="logo-sub">Indonesia Market Intelligence</span>
      <span class="private-badge">Private</span>
    </div>
    <button class="mobile-menu-btn" aria-label="Menu" id="menuBtn">
      <span></span><span></span><span></span>
    </button>
    <nav class="topbar-nav" id="mainNav">
      <a href="/" class="nav-link {% if page.url == '/' %}active{% endif %}">Home</a>
      <a href="/daily-summary" class="nav-link {% if page.url == '/daily-summary/' %}active{% endif %}">Summary</a>
      <a href="/portfolio" class="nav-link {% if page.url == '/portfolio/' %}active{% endif %}">Portfolio</a>
      <a href="/portfolio-history" class="nav-link {% if page.url == '/portfolio-history/' %}active{% endif %}">History</a>
      <a href="/earnings" class="nav-link {% if page.url == '/earnings/' %}active{% endif %}">Earnings</a>
      <a href="/alerts" class="nav-link {% if page.url == '/alerts/' %}active{% endif %}">Alerts</a>
      <a href="/top-picks" class="nav-link {% if page.url == '/top-picks/' %}active{% endif %}">Top Picks</a>
      <button id="logoutBtn" class="nav-link logout-btn" style="display:none">Logout</button>
    </nav>
    
    <script>
    // Check auth and show logout
    (async () => {
      const res = await fetch('/api/me', { credentials: 'same-origin' });
      if (res.ok) {
        const btn = document.getElementById('logoutBtn');
        if (btn) btn.style.display = 'inline-block';
      }
    })();
    
    document.getElementById('logoutBtn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin' });
      window.location.href = '/login/';
    });
    </script>
  </div>
</header>