---
layout: layouts/base.njk
title: Login - Insider Hub
---

<div class="auth-container">
  <form id="login-form" class="auth-form">
    <h1>🔐 Sign In</h1>
    <p class="subtitle">Access your portfolio data</p>
    
    <div class="field">
      <label for="email">Email</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        required 
        autocomplete="email"
        placeholder="you@example.com"
      />
    </div>
    
    <div class="field">
      <label for="password">Password</label>
      <input 
        type="password" 
        id="password" 
        name="password" 
        required
        autocomplete="current-password"
        minlength="6"
        placeholder="••••••"
      />
    </div>
    
    <button type="submit" class="btn-primary">
      <span class="text">Sign In</span>
      <span class="spinner" hidden>Loading...</span>
    </button>
    
    <p class="error" role="alert" hidden></p>
  </form>
</div>

<style>
.auth-container {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem 1rem;
}

.auth-form {
  width: 100%;
  max-width: 400px;
  padding: 2rem;
  background: var(--card-bg, #fff);
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

.auth-form h1 {
  margin: 0 0 0.5rem;
  font-size: 1.5rem;
}

.subtitle {
  color: var(--text-muted, #666);
  margin-bottom: 1.5rem;
}

.field {
  margin-bottom: 1rem;
}

.field label {
  display: block;
  margin-bottom: 0.25rem;
  font-weight: 500;
  font-size: 0.875rem;
}

.field input {
  width: 100%;
  padding: 0.75rem;
  border: 1px solid #ddd;
  border-radius: 6px;
  font-size: 16px; /* Prevents iOS zoom */
  box-sizing: border-box;
}

.field input:focus {
  outline: none;
  border-color: #0066cc;
}

.btn-primary {
  width: 100%;
  padding: 0.875rem;
  margin-top: 0.5rem;
  background: #0066cc;
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 16px;
  font-weight: 500;
  cursor: pointer;
  min-height: 44px;
}

.btn-primary:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.spinner {
  display: inline-block;
}

.error {
  color: #d32f2f;
  margin-top: 1rem;
  font-size: 0.875rem;
  text-align: center;
}

.error:not([hidden]) {
  display: block;
}
</style>

<script>
document.getElementById('login-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  const btn = form.querySelector('button');
  const spinner = btn.querySelector('.spinner');
  const text = btn.querySelector('.text');
  const error = form.querySelector('.error');
  
  // Loading state
  btn.disabled = true;
  text.hidden = true;
  spinner.hidden = false;
  error.hidden = true;
  
  try {
    const res = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        email: form.email.value,
        password: form.password.value
      }),
      credentials: 'same-origin'
    });
    
    if (res.ok) {
      const params = new URLSearchParams(window.location.search);
      const redirect = params.get('redirect') || '/portfolio/';
      window.location.href = redirect;
    } else {
      const data = await res.json().catch(() => ({}));
      error.textContent = data.error || 'Invalid email or password';
      error.hidden = false;
    }
  } catch (err) {
    error.textContent = 'Network error. Please try again.';
    error.hidden = false;
  } finally {
    btn.disabled = false;
    text.hidden = false;
    spinner.hidden = true;
  }
});
</script>
