---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Insider Hub - Macro & Micro Economic Intelligence for Indonesian Markets" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
		<style is:global>
			:root {
				--bg:          #f5f0e8;
				--bg-raised:   #faf7f2;
				--bg-subtle:   #ede8df;
				--border:      #d8d0c4;
				--border-soft: #e4ddd4;

				--text:        #111110;
				--text-2:      #5c5955;
				--text-3:      #a09c98;

				--up:          #1a6e3c;
				--up-bg:       #edf7f1;
				--down:        #b52828;
				--down-bg:     #fdf0f0;
				--amber:       #7a5c1e;
				--amber-bg:    #fdf6e8;

				--sans: 'IBM Plex Sans', system-ui, sans-serif;
				--mono: 'IBM Plex Mono', 'Courier New', monospace;
			}

			*, *::before, *::after {
				margin: 0; padding: 0; box-sizing: border-box;
			}

			html {
				background: var(--bg);
				color: var(--text);
				font-family: var(--sans);
				font-size: 14px;
				line-height: 1.5;
				-webkit-font-smoothing: antialiased;
			}

			body { min-height: 100vh; }

			a { color: inherit; text-decoration: none; }
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
