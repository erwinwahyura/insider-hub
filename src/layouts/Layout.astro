---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Insider Hub - Macro & Micro Economic Intelligence for Indonesian Markets" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style is:global>
			:root {
				--background: #0a0a0f;
				--surface: #14141a;
				--border: #23232a;
				--accent-green: #00d084;
				--accent-red: #ff4757;
				--accent-gold: #ffa502;
				--accent-blue: #3742fa;
				--text: #e4e4e7;
				--text-muted: #a1a1aa;
			}
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}
			html {
				background: var(--background);
				color: var(--text);
				font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
			}
			body {
				min-height: 100vh;
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
