---
layout: layouts/base.njk
title: Home
---

{% set bullishCount = 0 %}
{% set bearishCount = 0 %}
{% set macroCount = 0 %}
{% for item in news %}
  {% if item.impact == 'positive' %}{% set bullishCount = bullishCount + 1 %}{% endif %}
  {% if item.impact == 'negative' %}{% set bearishCount = bearishCount + 1 %}{% endif %}
  {% if item.category == 'macro' %}{% set macroCount = macroCount + 1 %}{% endif %}
{% endfor %}

<!-- Smart Money Summary -->
<div class="smart-money-summary">
  <div class="sm-header">
    <span class="sm-title">🎯 Smart Money Today</span>
    <span class="sm-time">{{ smartMoney.timestamp | dateFormat }}</span>
  </div>
  <div class="sm-stats">
    <div class="sm-stat buy">
      <span class="sm-num">{{ smartMoney.summary.accumulationCount }}</span>
      <span class="sm-label">Accumulating</span>
    </div>
    <div class="sm-stat sell">
      <span class="sm-num">{{ smartMoney.summary.distributionCount }}</span>
      <span class="sm-label">Distributing</span>
    </div>
    <div class="sm-stat">
      <span class="sm-num">{{ foreignFlow.summary.topBuyers.length }}</span>
      <span class="sm-label">Foreign Buy</span>
    </div>
    <div class="sm-stat">
      <span class="sm-num">{{ blockTrades.count }}</span>
      <span class="sm-label">Block Trades</span>
    </div>
  </div>
  {% if smartMoney.summary.topSignals.length > 0 %}
  <div class="sm-signals">
    {% for signal in smartMoney.summary.topSignals.slice(0, 3) %}
    <div class="sm-signal {{ signal.signal | lower }}">
      <span class="sm-ticker">{{ signal.ticker }}</span>
      <span class="sm-pattern">{{ signal.pattern | replace('_', ' ') }}</span>
      <span class="sm-conf {{ signal.confidence | lower }}">{{ signal.confidence }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}
</div>

<!-- Foreign Flow -->
<div class="foreign-flow">
  <div class="ff-header">
    <span class="ff-title">🌏 Foreign Flow (IDR)</span>
    <span class="ff-net {% if foreignFlow.summary.netFlow > 0 %}up{% else %}down{% endif %}">
      {% if foreignFlow.summary.netFlow > 0 %}+{% endif %}{{ (foreignFlow.summary.netFlow / 1000000000).toFixed(1) }}B
    </span>
  </div>
  <div class="ff-bars">
    {% for ticker in ['ESSA', 'BBCA', 'BBRI', 'PGEO', 'PTPS', 'ITMG'] %}
    {% set flow = foreignFlow.tickers[ticker] %}
    {% if flow %}
    <div class="ff-row">
      <span class="ff-ticker">{{ ticker }}</span>
      <div class="ff-bar-wrap">
        <div class="ff-bar {% if flow.netFlow > 0 %}buy{% else %}sell{% endif %}" 
             style="width: {{ (flow.netFlow | abs / 100000000) | min(100) }}%">
        </div>
      </div>
      <span class="ff-val {% if flow.netFlow > 0 %}up{% else %}down{% endif %}">
        {% if flow.netFlow > 0 %}+{% endif %}{{ (flow.netFlow / 1000000000).toFixed(1) }}B
      </span>
    </div>
    {% endif %}
    {% endfor %}
  </div>
</div>

<!-- Block Trades -->
{% if blockTrades.trades.length > 0 %}
<div class="block-trades">
  <div class="bt-header">
    <span class="bt-title">💼 Block Trades Today</span>
    <span class="bt-total">Rp {{ (blockTrades.totalBlockValue / 1000000000).toFixed(1) }}B</span>
  </div>
  {% for trade in blockTrades.trades.slice(0, 3) %}
  <div class="bt-trade {{ trade.type | lower }}">
    <div class="bt-main">
      <span class="bt-ticker">{{ trade.ticker }}</span>
      <span class="bt-type">{{ trade.type }}</span>
      <span class="bt-val">Rp {{ (trade.value / 1000000000).toFixed(1) }}B</span>
      <span class="bt-party">{{ trade.party }}</span>
    </div>
    <div class="bt-note">{{ trade.notes }}</div>
  </div>
  {% endfor %}
</div>
{% endif %}

<!-- Stats -->
<div class="stats-row">
  <div class="stat">
    <span class="stat-n mono up">{{ bullishCount }}</span>
    <span class="stat-l">Bullish</span>
  </div>
  <div class="stat">
    <span class="stat-n mono down">{{ bearishCount }}</span>
    <span class="stat-l">Bearish</span>
  </div>
  <div class="stat">
    <span class="stat-n mono amber">{{ macroCount }}</span>
    <span class="stat-l">Macro</span>
  </div>
  <div class="stat">
    <span class="stat-n mono">{{ news.length }}</span>
    <span class="stat-l">Articles</span>
  </div>
  <div class="stat">
    <span class="stat-n mono dim">{{ news[0].date | dateFormat }}</span>
    <span class="stat-l">Updated</span>
  </div>
</div>

<!-- Market Overview Grid -->
<div style="display: grid; grid-template-columns: 1fr; gap: 1rem; margin-bottom: 1rem;">
  {% if stocks.stocks %}
  <!-- BI Rate Panel -->
  <div class="bi-rate-panel">
    <div class="bi-header">
      <span class="bi-tag">BI Rate</span>
      <span class="bi-tag">Monetary Policy</span>
    </div>
    <div class="bi-main">
      <span class="bi-rate">5.75%</span>
      <span class="bi-status">unchanged</span>
    </div>
    <div class="bi-details">
      <div class="bi-detail">
        <span class="bi-detail-label">Last decision</span>
        <span class="bi-detail-value">19 Mar 2025 — Hold</span>
      </div>
      <div class="bi-detail">
        <span class="bi-detail-label">Next meeting</span>
        <span class="bi-detail-value">23-24 Apr 2025</span>
      </div>
      <div class="bi-detail">
        <span class="bi-detail-label">Consensus</span>
        <span class="bi-detail-value">Hold expected</span>
      </div>
    </div>
  </div>
  
  <!-- Market Breadth -->
  <div class="market-breadth">
    <div class="breadth-header">
      <span class="breadth-title">Market Breadth</span>
      <span class="breadth-status weak">Weak</span>
    </div>
    <div class="breadth-stats">
      <div class="breadth-stat up">
        <span class="breadth-num">312</span>
        <span class="breadth-label">Advancing</span>
      </div>
      <div class="breadth-stat down">
        <span class="breadth-num">489</span>
        <span class="breadth-label">Declining</span>
      </div>
      <div class="breadth-stat neutral">
        <span class="breadth-num">121</span>
        <span class="breadth-label">Unchanged</span>
      </div>
    </div>
    <div class="breadth-details">
      <div class="breadth-detail">
        <span>A/D Ratio</span>
        <span>0.64 — more sellers than buyers</span>
      </div>
      <div class="breadth-detail">
        <span>52w High</span>
        <span>18 stocks</span>
      </div>
      <div class="breadth-detail">
        <span>52w Low</span>
        <span>47 stocks</span>
      </div>
    </div>
  </div>
  
  <!-- Foreign Investor Net Flow -->
  <div class="foreign-net-flow">
    <div class="fnf-header">
      <span class="fnf-title">Foreign Investor Net Flow</span>
      <span class="fnf-status sell">Net Sell</span>
    </div>
    <div class="fnf-main sell">-Rp 2.34T net sell this week</div>
    <div class="fnf-details">
      <div class="fnf-detail">
        <span class="fnf-detail-label">Gross Buy</span>
        <span class="fnf-detail-value">Rp 8.12T</span>
      </div>
      <div class="fnf-detail">
        <span class="fnf-detail-label">Gross Sell</span>
        <span class="fnf-detail-value">Rp 10.46T</span>
      </div>
      <div class="fnf-detail">
        <span class="fnf-detail-label">YTD Net</span>
        <span class="fnf-detail-value">-Rp 18.7T</span>
      </div>
    </div>
    <div class="fnf-chart">
      <div class="fnf-chart-title">4-week net flow (IDR Trillion)</div>
      <div class="fnf-weeks">
        <div class="fnf-week">
          <span class="fnf-week-label">W-4</span>
          <div class="fnf-week-bar-wrap">
            <div class="fnf-week-bar buy" style="width: 25%"></div>
          </div>
          <span class="fnf-week-value">+1.2T</span>
        </div>
        <div class="fnf-week">
          <span class="fnf-week-label">W-3</span>
          <div class="fnf-week-bar-wrap">
            <div class="fnf-week-bar sell" style="width: 20%"></div>
          </div>
          <span class="fnf-week-value">-0.8T</span>
        </div>
        <div class="fnf-week">
          <span class="fnf-week-label">W-2</span>
          <div class="fnf-week-bar-wrap">
            <div class="fnf-week-bar sell" style="width: 35%"></div>
          </div>
          <span class="fnf-week-value">-1.5T</span>
        </div>
        <div class="fnf-week">
          <span class="fnf-week-label">W-1</span>
          <div class="fnf-week-bar-wrap">
            <div class="fnf-week-bar sell" style="width: 55%"></div>
          </div>
          <span class="fnf-week-value">-2.34T</span>
        </div>
      </div>
    </div>
  </div>
  {% endif %}
</div>

<!-- Sector Performance -->
<div class="sector-performance">
  <div class="sector-header">
    <span class="sector-title">Sector Performance</span>
    <span class="sector-source">IDX Sector Indices · YTD 2025</span>
  </div>
  <div class="sector-list">
    <div class="sector-item">
      <div class="sector-left">
        <span class="sector-name">Energy</span>
        <span class="sector-tickers">ADRO · ITMG · PTBA</span>
      </div>
      <div class="sector-right">
        <span class="sector-change up">+8.4%</span>
        <span class="sector-period">YTD</span>
      </div>
    </div>
    <div class="sector-item">
      <div class="sector-left">
        <span class="sector-name">Basic Materials</span>
        <span class="sector-tickers">ANTM · INCO · TINS</span>
      </div>
      <div class="sector-right">
        <span class="sector-change up">+5.2%</span>
        <span class="sector-period">YTD</span>
      </div>
    </div>
    <div class="sector-item">
      <div class="sector-left">
        <span class="sector-name">Consumer Cyclical</span>
        <span class="sector-tickers">MAPI · ACES · ERAA</span>
      </div>
      <div class="sector-right">
        <span class="sector-change up">+2.1%</span>
        <span class="sector-period">YTD</span>
      </div>
    </div>
    <div class="sector-item">
      <div class="sector-left">
        <span class="sector-name">Financials</span>
        <span class="sector-tickers">BBRI · BBCA · BMRI</span>
      </div>
      <div class="sector-right">
        <span class="sector-change down">-1.3%</span>
        <span class="sector-period">YTD</span>
      </div>
    </div>
    <div class="sector-item">
      <div class="sector-left">
        <span class="sector-name">Industrials</span>
        <span class="sector-tickers">ASII · SMGR · INTP</span>
      </div>
      <div class="sector-right">
        <span class="sector-change down">-2.8%</span>
        <span class="sector-period">YTD</span>
      </div>
    </div>
    <div class="sector-item">
      <div class="sector-left">
        <span class="sector-name">Healthcare</span>
        <span class="sector-tickers">SIDO · KLBF · MIKA</span>
      </div>
      <div class="sector-right">
        <span class="sector-change down">-3.5%</span>
        <span class="sector-period">YTD</span>
      </div>
    </div>
    <div class="sector-item">
      <div class="sector-left">
        <span class="sector-name">Technology</span>
        <span class="sector-tickers">GOTO · BUKA · EMTK</span>
      </div>
      <div class="sector-right">
        <span class="sector-change down">-5.1%</span>
        <span class="sector-period">YTD</span>
      </div>
    </div>
  </div>
</div>

<!-- Commodities -->
<div class="commodities">
  {% set comms = [
    {key: 'coal', name: 'Coal', sub: 'Newcastle', unit: '$'},
    {key: 'nickel', name: 'Nickel', sub: 'LME', unit: '$'},
    {key: 'cpo', name: 'Palm Oil', sub: 'CPO', unit: 'RM '},
    {key: 'gold', name: 'Gold', sub: 'Spot', unit: '$'},
    {key: 'idr_usd', name: 'IDR/USD', sub: '', unit: ''}
  ] %}
  
  {% for c in comms %}
    {% set data = commodities.commodities[c.key] %}
    {% set direction = 'neutral' %}
    {% if data.changePct > 0 %}{% set direction = 'up' %}{% endif %}
    {% if data.changePct < 0 %}{% set direction = 'down' %}{% endif %}
    
    <div class="commodity {{ direction }}">
      <span class="comm-name">{{ c.name }} {% if c.sub %}<span style="font-size:11px;color:var(--text-3);font-weight:400;">{{ c.sub }}</span>{% endif %}</span>
      <div class="comm-right">
        <span class="comm-price mono">{{ c.unit }}{{ data.price.toLocaleString() }}</span>
        <span class="comm-delta mono {{ direction }}">
          {% if data.changePct > 0 %}▲{% endif %}
          {% if data.changePct < 0 %}▼{% endif %}
          {{ data.changePct.toFixed(2) }}%
        </span>
      </div>
    </div>
  {% endfor %}
</div>

<!-- News List -->
<h2>Latest News</h2>
<div class="news-list">
  {% for item in news.slice(0, 10) %}
    {% set impact = 'neutral' %}
    {% if item.impact == 'positive' %}{% set impact = 'up' %}{% endif %}
    {% if item.impact == 'negative' %}{% set impact = 'down' %}{% endif %}
    
    <a href="/news/{{ item.id }}" class="news-card">
      <div class="news-bar {{ impact }}"></div>
      <div class="news-content">
        <div class="news-meta">
          <span>{{ item.date | dateFormat }}</span>
          <span>{{ item.source }}</span>
          <span class="impact-tag {{ impact }}">
            {% if item.impact == 'positive' %}▲{% endif %}
            {% if item.impact == 'negative' %}▼{% endif %}
            {% if item.impact == 'neutral' %}→{% endif %}
            {{ item.impact }}
          </span>
          <span class="badge badge-neutral">{{ item.category }}</span>
        </div>
        <div class="news-title">{{ item.title }}</div>
        {% if item.tickers and item.tickers.length > 0 %}
          <div class="news-chips">
            {% for ticker in item.tickers %}
              <span class="chip">{{ ticker }}</span>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </a>
  {% endfor %}
</div>