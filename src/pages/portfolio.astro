---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio — Insider Hub">
<div class="page">

  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <span class="logo">Insider Hub</span>
        <span class="logo-sub">Portfolio Dashboard</span>
        <span class="private-badge">Private</span>
      </div>
      <div class="topbar-right">
        <a href="/" class="nav-link">← News Feed</a>
        <a href="/top-picks" class="nav-link">Top Picks</a>
      </div>
    </div>
  </header>

  <div class="body">

    <!-- Portfolio Overview -->
    <section class="section">
      <div class="section-head">
        <h2 class="section-title">Portfolio Overview</h2>
        <p class="section-sub">April 2026 • Om Obet Framework</p>
      </div>

      <div class="cards-row">
        <div class="stat-card">
          <div class="stat-label">Total Equity</div>
          <div class="stat-value">Rp 67.4M</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Cash Available</div>
          <div class="stat-value" style="color: var(--up)">Rp 62.0M</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Assets</div>
          <div class="stat-value">Rp 129.4M</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Cash %</div>
          <div class="stat-value" style="color: var(--amber)">48%</div>
        </div>
      </div>
    </section>

    <!-- Core Holdings -->
    <section class="section">
      <div class="section-head">
        <h2 class="section-title">Core Holdings (Priority Actions)</h2>
      </div>

      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Ticker</th>
              <th>Value</th>
              <th>Avg Buy</th>
              <th>Current</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <tr class="priority-high">
              <td><strong>ESSA</strong></td>
              <td>Rp 18.7M</td>
              <td>Rp 722</td>
              <td>Rp 690-695</td>
              <td><span class="badge down">-3.7% to -4.4%</span></td>
              <td><span class="action-exit">PARTIAL EXIT 50-70%</span></td>
            </tr>
            <tr>
              <td><strong>PGEO</strong></td>
              <td>Rp 20.8M</td>
              <td>—</td>
              <td>~700</td>
              <td><span class="badge neutral">HOLD</span></td>
              <td>Monitor payout ratio (97% unsustainable)</td>
            </tr>
            <tr>
              <td><strong>PTPS</strong></td>
              <td>Rp 19.9M</td>
              <td>—</td>
              <td>—</td>
              <td><span class="badge warn">NEEDS ANALYSIS</span></td>
              <td>15% of portfolio — priority keystat</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Watchlist -->
    <section class="section">
      <div class="section-head">
        <h2 class="section-title">Watchlist</h2>
        <p class="section-sub">Targets for deployment</p>
      </div>

      <div class="cards-grid">
        <div class="news-card">
          <div class="news-header">
            <span class="news-ticker up">ISSP</span>
            <span class="badge up">BUY ✅</span>
          </div>
          <div class="news-title">Top Redeployment Target</div>
          <div class="news-body">
            <p>PER 5.95 | PBV 0.61 | PEG 0.93</p>
            <p>Insider buying + Unit 7 capex catalyst</p>
          </div>
          <div class="news-footer">
            <span class="dim">Score: 7.5/10</span>
            <span class="up">Om Obet: LULUS</span>
          </div>
        </div>

        <div class="news-card">
          <div class="news-header">
            <span class="news-ticker warn">ELSA</span>
            <span class="badge warn">WAIT ⚠️</span>
          </div>
          <div class="news-title">Governance Risk</div>
          <div class="news-body">
            <p>BPK audit fraud findings | Management risk</p>
            <p>PER 7.52 attractive but WAIT for clarity</p>
          </div>
          <div class="news-footer">
            <span class="dim">Score: 8/10 → WAIT</span>
            <span class="warn">Governance override</span>
          </div>
        </div>

        <div class="news-card">
          <div class="news-header">
            <span class="news-ticker down">ITMG</span>
            <span class="badge down">CYCLICAL ⚠️</span>
          </div>
          <div class="news-title">Geopolitik Play Only</div>
          <div class="news-body">
            <p>PER 6.48 | Div 13.83% | Laba -71%</p>
            <p>Payout 118% unsustainable</p>
          </div>
          <div class="news-footer">
            <span class="dim">Score: 7/10</span>
            <span class="down">Optional play</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Action Plan -->
    <section class="section">
      <div class="section-head">
        <h2 class="section-title">Active Action Plan</h2>
      </div>

      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Priority</th>
              <th>Ticker</th>
              <th>Action</th>
              <th>Amount</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            <tr class="priority-high">
              <td>🔴 HIGH</td>
              <td>ESSA</td>
              <td><span class="action-exit">Partial Exit</span></td>
              <td>Rp 9-13M</td>
              <td>Sell 50-70% at 690-695, redeploy to ISSP</td>
            </tr>
            <tr class="priority-high">
              <td>🔴 HIGH</td>
              <td>ISSP</td>
              <td><span class="action-buy">Entry</span></td>
              <td>Rp 12M (20%)</td>
              <td>Cicil 40-30-30 method at ~430s</td>
            </tr>
            <tr class="priority-high">
              <td>🔴 HIGH</td>
              <td>PTPS</td>
              <td><span class="action-analyze">Keystat</span></td>
              <td>—</td>
              <td>Complete analysis — 15% of portfolio</td>
            </tr>
            <tr class="priority-med">
              <td>🟡 MED</td>
              <td>ELSA</td>
              <td><span class="action-hold">WAIT</span></td>
              <td>Rp 25M (40%)</td>
              <td>Hold cash allocation until BPK clear</td>
            </tr>
            <tr class="priority-low">
              <td>🟢 LOW</td>
              <td>BSSR/AADI</td>
              <td><span class="action-dca">DCA</span></td>
              <td>Rp 9M (15%)</td>
              <td>Top-up dividend DCA positions</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Framework Reminder -->
    <section class="section">
      <div class="section-head">
        <h2 class="section-title">Om Obet Framework</h2>
      </div>

      <div class="cards-grid" style="grid-template-columns: repeat(3, 1fr);">
        <div class="news-card">
          <div class="news-title">1. Management Effectiveness</div>
          <div class="news-body">
            <ul class="body-list">
              <li>ROE, ROA, ROIC trends</li>
              <li>Insider activity (buy/sell)</li>
              <li>Governance red flags (BPK/audit)</li>
            </ul>
          </div>
        </div>
        <div class="news-card">
          <div class="news-title">2. Solvency</div>
          <div class="news-body">
            <ul class="body-list">
              <li>D/E ratio (&lt;0.5 🟢)</li>
              <li>Altman Z-Score (&gt;2.99 🟢)</li>
              <li>Current ratio (&gt;1.5 🟢)</li>
            </ul>
          </div>
        </div>
        <div class="news-card">
          <div class="news-title">3. Valuation</div>
          <div class="news-body">
            <ul class="body-list">
              <li>PER (&lt;10 🟢), PBV (&lt;1 🟢)</li>
              <li>Div Yield (&gt;5% 🟢)</li>
              <li>PEG (&lt;1 🟢)</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="note-panel">
        <p><strong>Hard Rule:</strong> "Would I buy this fresh today at this price?"<br>
        If <strong>NO</strong> → Consider exiting. Governance red flags override all attractive valuations.</p>
      </div>
    </section>

  </div>
</div>

<style>
  /* Layout */
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  
  /* Topbar */
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 860px;
  }
  .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
  .topbar-right { display: flex; align-items: center; gap: 1rem; }
  .logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .logo-sub { font-size: 12px; color: var(--text-3); }
  .private-badge {
    font-size: 10px; font-weight: 500; color: var(--text-3);
    border: 1px solid var(--border); padding: 1px 6px; border-radius: 3px;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .dim { font-size: 12px; color: var(--text-3); }
  .mono { font-family: var(--mono); }
  .nav-link {
    font-size: 12px; color: var(--text-3); text-decoration: none;
    border: 1px solid var(--border); padding: 2px 8px; border-radius: 4px;
    transition: all 0.15s;
  }
  .nav-link:hover { color: var(--text); border-color: var(--up); background: var(--up-bg); }

  /* Body */
  .body { flex: 1; padding: 1.25rem 1.5rem; max-width: 860px; margin: 0 auto; width: 100%; }

  /* Section */
  .section { margin-bottom: 1.5rem; }
  .section-head { margin-bottom: 0.75rem; }
  .section-title { font-size: 14px; font-weight: 600; color: var(--text); margin: 0 0 0.25rem; }
  .section-sub { font-size: 12px; color: var(--text-3); margin: 0; }

  /* Cards Grid */
  .cards-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;
  }
  @media (min-width: 860px) { .cards-grid { grid-template-columns: repeat(3, 1fr); } }
  
  .cards-row {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;
  }
  @media (min-width: 640px) { .cards-row { grid-template-columns: repeat(4, 1fr); } }

  /* Stat Card */
  .stat-card {
    background: var(--bg-raised); border: 1px solid var(--border); border-radius: 6px;
    padding: 0.75rem; text-align: center;
  }
  .stat-label { font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; }
  .stat-value { font-size: 16px; font-weight: 600; color: var(--text); }

  /* News Card */
  .news-card {
    display: flex; flex-direction: column; gap: 0.5rem;
    background: var(--bg-raised); border: 1px solid var(--border); border-radius: 6px;
    padding: 0.75rem; transition: all 0.15s;
  }
  .news-card:hover { border-color: var(--border-soft); transform: translateY(-1px); box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .news-header { display: flex; align-items: center; gap: 0.5rem; }
  .news-ticker {
    font-size: 11px; font-weight: 600; padding: 2px 6px; border-radius: 4px;
    background: var(--bg-subtle); color: var(--text-2);
  }
  .news-ticker.up { background: var(--up-bg); color: var(--up); }
  .news-ticker.down { background: var(--down-bg); color: var(--down); }
  .news-ticker.warn { background: var(--amber-bg); color: var(--amber); }
  .news-title { font-size: 13px; font-weight: 500; color: var(--text); line-height: 1.4; }
  .news-body { font-size: 12px; color: var(--text-2); line-height: 1.5; }
  .news-body p { margin: 0 0 0.25rem; }
  .news-footer {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 11px; margin-top: auto; padding-top: 0.25rem;
  }

  /* Badge */
  .badge {
    font-size: 10px; font-weight: 500; padding: 2px 6px; border-radius: 4px;
    background: var(--bg-subtle); color: var(--text-3);
  }
  .badge.up { background: var(--up-bg); color: var(--up); }
  .badge.down { background: var(--down-bg); color: var(--down); }
  .badge.warn { background: var(--amber-bg); color: var(--amber); }
  .badge.neutral { background: var(--bg-subtle); color: var(--text-2); }

  /* Colors */
  .up { color: var(--up); font-weight: 500; }
  .down { color: var(--down); font-weight: 500; }
  .warn { color: var(--amber); font-weight: 500; }

  /* Table */
  .table-wrap { overflow-x: auto; }
  .data-table {
    width: 100%; border-collapse: collapse; font-size: 12px;
    background: var(--bg-raised); border: 1px solid var(--border); border-radius: 6px;
  }
  .data-table thead { background: var(--bg-subtle); }
  .data-table th {
    text-align: left; padding: 0.5rem 0.75rem; font-weight: 500; color: var(--text-2);
    border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .data-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border-soft); color: var(--text); }
  .data-table tbody tr:hover { background: var(--bg-subtle); }
  .data-table tbody tr:last-child td { border-bottom: none; }

  /* Priority indicators */
  .priority-high { border-left: 3px solid var(--down); }
  .priority-med { border-left: 3px solid var(--amber); }
  .priority-low { border-left: 3px solid var(--up); }

  /* Action buttons */
  .action-exit {
    display: inline-block; background: var(--down); color: #fff;
    padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600;
  }
  .action-buy {
    display: inline-block; background: var(--up); color: #fff;
    padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600;
  }
  .action-hold {
    display: inline-block; background: var(--amber); color: #fff;
    padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600;
  }
  .action-analyze {
    display: inline-block; background: var(--text-2); color: #fff;
    padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600;
  }
  .action-dca {
    display: inline-block; background: var(--text-3); color: #fff;
    padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 600;
  }

  /* Note panel */
  .note-panel {
    background: var(--amber-bg); border: 1px solid var(--amber-bg);
    border-radius: 6px; padding: 0.75rem; margin-top: 1rem;
  }
  .note-panel p { margin: 0; font-size: 12px; color: var(--amber); line-height: 1.5; }

  /* Body list */
  .body-list { list-style: none; padding: 0; margin: 0; }
  .body-list li { padding: 4px 0; border-bottom: 1px solid var(--border-soft); font-size: 12px; color: var(--text-2); }
  .body-list li:last-child { border-bottom: none; }

  /* Responsive */
  @media (max-width: 640px) {
    .cards-grid { grid-template-columns: 1fr; }
    .cards-row { grid-template-columns: repeat(2, 1fr); }
    .data-table { font-size: 11px; }
    .data-table th, .data-table td { padding: 0.375rem 0.5rem; }
  }
</style>
</Layout>
