---
import Layout from '../layouts/Layout.astro';
import { readFile } from 'fs/promises';
import { existsSync } from 'fs';

// Load stock prices
const PRICES_FILE = './src/content/data/stock-prices.json';
let stockData: any = null;

if (existsSync(PRICES_FILE)) {
  try {
    const raw = await readFile(PRICES_FILE, 'utf-8');
    stockData = JSON.parse(raw);
  } catch (e) {
    console.error('Failed to load stock prices:', e);
  }
}

// Portfolio positions
const positions = [
  { ticker: 'PTPS', lots: 1560, avgPrice: 191, sector: 'CPO/Plantation', conviction: 'HIGH' },
  { ticker: 'PGEO', lots: 245, avgPrice: 1010, sector: 'Geothermal/Energy', conviction: 'CORE' },
  { ticker: 'ESSA', lots: 310, avgPrice: 713, sector: 'Ammonia/Chemical', conviction: 'HOLD' },
];

const cash = 56000000;

// Merge with live prices
const positionsWithLive = positions.map(pos => {
  const live = stockData?.stocks?.[pos.ticker];
  if (live && live.price) {
    const currentPrice = live.price;
    const invested = pos.lots * 100 * pos.avgPrice;
    const marketValue = pos.lots * 100 * currentPrice;
    const pnl = marketValue - invested;
    const pnlPct = (pnl / invested) * 100;
    
    return {
      ...pos,
      currentPrice,
      invested,
      marketValue,
      pnl,
      pnlPct,
      dayChange: live.changePct,
      volume: live.volume,
      lastUpdate: live.timestamp,
      isLive: true,
    };
  }
  return { ...pos, isLive: false };
});

// Calculate totals
const totalInvested = positionsWithLive.reduce((sum, p) => sum + (p.invested || 0), 0);
const totalMarketValue = positionsWithLive.reduce((sum, p) => sum + (p.marketValue || 0), 0);
const totalPnl = positionsWithLive.reduce((sum, p) => sum + (p.pnl || 0), 0);
const totalEquity = totalMarketValue + cash;

// Allocation percentages
const positionsWithAlloc = positionsWithLive.map(p => ({
  ...p,
  allocPct: totalMarketValue > 0 ? ((p.marketValue || 0) / totalMarketValue) * 100 : 0,
}));

function formatCurrency(n: number) {
  if (n >= 1000000000) return `Rp ${(n / 1000000000).toFixed(1)}B`;
  if (n >= 1000000) return `Rp ${(n / 1000000).toFixed(1)}M`;
  return `Rp ${n.toLocaleString()}`;
}

function formatNumber(n: number) {
  return n.toLocaleString();
}

function pnlClass(pnl: number) {
  return pnl >= 0 ? 'up' : 'down';
}

function convictionBadge(conv: string) {
  if (conv === 'HIGH') return 'high';
  if (conv === 'CORE') return 'core';
  return 'hold';
}

const lastUpdate = stockData?.timestamp || new Date().toISOString();
---

<Layout title="Portfolio — Insider Hub">
<div class="page">
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="logo">Insider Hub</a>
        <span class="logo-sub">Portfolio Tracker</span>
      </div>
      <nav class="topbar-nav">
        <a href="/" class="nav-link">Home</a>
        <a href="/daily-summary" class="nav-link">Summary</a>
        <a href="/portfolio" class="nav-link">Portfolio</a>
        <a href="/earnings" class="nav-link">Earnings</a>
        <a href="/alerts" class="nav-link">Alerts</a>
        <a href="/top-picks" class="nav-link">Top Picks</a>
        <span class="nav-stats">
          <span class="mono dim">Live</span>
          <span class="live-badge">●</span>
        </span>
      </nav>
    </div>
  </header>

  <div class="body">
    <!-- Summary Cards -->
    <section class="summary-grid">
      <div class="summary-card total">
        <div class="card-label">Total Equity</div>
        <div class="card-value mono">{formatCurrency(totalEquity)}</div>
        <div class="card-sub">
          <span class="mono">{formatCurrency(totalMarketValue)}</span> invested
          <span class="dim"> + {formatCurrency(cash)} cash</span>
        </div>
      </div>
      
      <div class={`summary-card pnl ${pnlClass(totalPnl)}`}>
        <div class="card-label">Unrealized P&L</div>
        <div class="card-value mono">
          {totalPnl >= 0 ? '+' : ''}{formatCurrency(totalPnl)}
        </div>
        <div class="card-sub">
          <span class="mono">{totalPnl >= 0 ? '+' : ''}{((totalPnl / totalInvested) * 100).toFixed(2)}%</span>
          <span class="dim"> vs avg cost</span>
        </div>
      </div>
      
      <div class="summary-card cash">
        <div class="card-label">Cash Available</div>
        <div class="card-value mono">{formatCurrency(cash)}</div>
        <div class="card-sub">
          <span class="mono">{((cash / totalEquity) * 100).toFixed(1)}%</span>
          <span class="dim"> of portfolio</span>
        </div>
      </div>
    </section>

    <!-- Allocation Bar -->
    <section class="allocation-bar">
      <div class="alloc-label">Allocation</div>
      <div class="alloc-stack">
        {positionsWithAlloc.map((p, i) => (
          <div 
            class={`alloc-segment ${p.ticker.toLowerCase()}`} 
            style={`width: ${p.allocPct}%`}
            title={`${p.ticker}: ${p.allocPct.toFixed(1)}%`}
          ></div>
        ))}
        <div class="alloc-segment cash" style={`width: ${(cash / totalEquity) * 100}%`}></div>
      </div>
      <div class="alloc-legend">
        {positionsWithAlloc.map(p => (
          <div class="legend-item">
            <span class={`legend-dot ${p.ticker.toLowerCase()}`}></span>
            <span class="legend-ticker">{p.ticker}</span>
            <span class="legend-pct">{p.allocPct.toFixed(1)}%</span>
          </div>
        ))}
        <div class="legend-item">
          <span class="legend-dot cash"></span>
          <span class="legend-ticker">Cash</span>
          <span class="legend-pct">{((cash / totalEquity) * 100).toFixed(1)}%</span>
        </div>
      </div>
    </section>

    <!-- Holdings Table -->
    <section class="holdings-panel">
      <div class="panel-head">
        <span class="panel-title">Holdings</span>
        <span class="panel-badge">{positions.length} Positions</span>
        <span class="last-update mono dim">Updated {new Date(lastUpdate).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'})}</span>
      </div>
      
      <div class="holdings-table">
        <div class="table-header">
          <span class="col-ticker">Ticker</span>
          <span class="col-sector">Sector</span>
          <span class="col-lots">Lots</span>
          <span class="col-avg">Avg Price</span>
          <span class="col-current">Current</span>
          <span class="col-day">Day</span>
          <span class="col-pnl">P&L</span>
          <span class="col-value">Value</span>
          <span class="col-alloc">Alloc</span>
        </div>
        
        {positionsWithAlloc.map(p => (
          <div class="table-row">
            <div class="col-ticker">
              <span class="ticker-name">{p.ticker}</span>
              <span class={`conviction-badge ${convictionBadge(p.conviction)}`}>{p.conviction}</span>
            </div>
            <span class="col-sector dim">{p.sector}</span>
            <span class="col-lots mono">{formatNumber(p.lots)}</span>
            <span class="col-avg mono">{p.avgPrice.toLocaleString()}</span>
            <span class="col-current mono">{p.currentPrice?.toLocaleString() || '-'}</span>
            <span class={`col-day mono ${pnlClass(p.dayChange || 0)}`}>
              {p.dayChange !== undefined ? `${p.dayChange >= 0 ? '+' : ''}${p.dayChange.toFixed(2)}%` : '-'}
            </span>
            <span class={`col-pnl mono ${pnlClass(p.pnl || 0)}`}>
              {p.pnl !== undefined ? `${p.pnl >= 0 ? '+' : ''}${formatCurrency(p.pnl)}` : '-'}
            </span>
            <span class="col-value mono">{p.marketValue ? formatCurrency(p.marketValue) : '-'}</span>
            <span class="col-alloc mono">{p.allocPct.toFixed(1)}%</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Quick Actions -->
    <section class="actions-panel">
      <div class="panel-head">
        <span class="panel-title">Quick Actions</span>
      </div>
      <div class="actions-grid">
        <a href="/" class="action-btn">
          <span class="action-icon">📈</span>
          <span class="action-label">View News</span>
        </a>
        <a href="/earnings" class="action-btn">
          <span class="action-icon">📅</span>
          <span class="action-label">Earnings Calendar</span>
        </a>
        <a href="/top-picks" class="action-btn">
          <span class="action-icon">⭐</span>
          <span class="action-label">Top Picks</span>
        </a>
      </div>
    </section>
  </div>

  <footer class="footer">
    Insider Hub · Live portfolio tracking · Updated every 30 min
  </footer>
</div>
</Layout>

<style is:global>
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  
  /* Topbar */
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 860px;
  }
  .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
  .logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .logo-sub { font-size: 12px; color: var(--text-3); }
  .topbar-nav {
    display: flex; align-items: center; gap: 1rem;
  }
  .nav-link {
    font-size: 12px; color: var(--text-3); text-decoration: none;
    border: 1px solid var(--border); padding: 2px 8px; border-radius: 4px;
  }
  .nav-link:hover { color: var(--text); border-color: var(--up); }
  .nav-stats {
    display: flex; align-items: center; gap: 0.5rem;
    margin-left: 0.75rem; padding-left: 0.75rem;
    border-left: 1px solid var(--border);
  }
  .live-badge {
    color: var(--up);
    font-size: 11px;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .mono { font-family: var(--mono); }
  .dim { color: var(--text-3); }
  .up { color: var(--up); }
  .down { color: var(--down); }

  /* Body */
  .body { flex: 1; padding: 1.25rem 1.5rem; max-width: 860px; margin: 0 auto; width: 100%; }

  /* Summary Grid */
  .summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .summary-card {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    padding: 1rem;
    border-radius: 4px;
    border-top: 3px solid var(--border);
  }
  .summary-card.total { border-top-color: #2563eb; }
  .summary-card.pnl.up { border-top-color: var(--up); }
  .summary-card.pnl.down { border-top-color: var(--down); }
  .summary-card.cash { border-top-color: var(--amber); }
  .card-label {
    font-size: 11px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }
  .card-value {
    font-size: 24px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.25rem;
  }
  .card-sub {
    font-size: 12px;
    color: var(--text-2);
  }

  /* Allocation Bar */
  .allocation-bar {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    padding: 1rem;
    margin-bottom: 1.5rem;
    border-radius: 4px;
  }
  .alloc-label {
    font-size: 11px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }
  .alloc-stack {
    display: flex;
    height: 24px;
    background: var(--border);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .alloc-segment {
    height: 100%;
    transition: opacity 0.2s;
  }
  .alloc-segment:hover { opacity: 0.8; }
  .alloc-segment.ptps { background: #22c55e; }
  .alloc-segment.pgeo { background: #3b82f6; }
  .alloc-segment.essa { background: #f59e0b; }
  .alloc-segment.cash { background: var(--border); }
  .alloc-legend {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 12px;
  }
  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
  }
  .legend-dot.ptps { background: #22c55e; }
  .legend-dot.pgeo { background: #3b82f6; }
  .legend-dot.essa { background: #f59e0b; }
  .legend-dot.cash { background: var(--text-3); }
  .legend-ticker { font-weight: 500; color: var(--text); }
  .legend-pct { color: var(--text-3); }

  /* Holdings Panel */
  .holdings-panel {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    margin-bottom: 1.5rem;
    border-radius: 4px;
    overflow: hidden;
  }
  .panel-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .panel-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .panel-badge {
    font-size: 10px;
    padding: 1px 6px;
    border-radius: 2px;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text-3);
  }
  .last-update {
    margin-left: auto;
    font-size: 11px;
  }
  
  .holdings-table {
    display: flex;
    flex-direction: column;
  }
  .table-header {
    display: grid;
    grid-template-columns: 100px 140px 60px 80px 80px 60px 100px 90px 50px;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--bg-subtle);
    font-size: 10px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border);
  }
  .table-row {
    display: grid;
    grid-template-columns: 100px 140px 60px 80px 80px 60px 100px 90px 50px;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border-soft);
    align-items: center;
    font-size: 12px;
  }
  .table-row:hover { background: var(--bg-subtle); }
  .col-ticker {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .ticker-name {
    font-weight: 600;
    color: var(--text);
  }
  .conviction-badge {
    font-size: 9px;
    padding: 1px 4px;
    border-radius: 2px;
    width: fit-content;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .conviction-badge.high {
    background: rgba(34, 197, 94, 0.15);
    color: #16a34a;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }
  .conviction-badge.core {
    background: rgba(59, 130, 246, 0.15);
    color: #2563eb;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }
  .conviction-badge.hold {
    background: rgba(245, 158, 11, 0.15);
    color: #d97706;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }

  /* Actions Panel */
  .actions-panel {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .actions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
  }
  .action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
    background: var(--bg-raised);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .action-btn:hover { background: var(--bg-subtle); }
  .action-icon { font-size: 24px; }
  .action-label { font-size: 12px; color: var(--text-2); }

  /* Footer */
  .footer {
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--border);
    text-align: center;
    font-size: 12px;
    color: var(--text-3);
    background: var(--bg-subtle);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .summary-grid { grid-template-columns: 1fr; }
    .table-header,
    .table-row {
      grid-template-columns: 80px 80px 50px 70px 60px 50px;
    }
    .col-sector, .col-alloc { display: none; }
    .actions-grid { grid-template-columns: 1fr; }
  }
</style>
