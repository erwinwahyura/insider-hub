---
import Layout from '../layouts/Layout.astro';
---

<!-- Client-side Clerk SignIn will be loaded via script -->

<Layout title="Sign In — Insider Hub">
<div class="page">
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="logo">Insider Hub</a>
        <span class="logo-sub">Portfolio Tracker</span>
      </div>
    </div>
  </header>

  <div class="body">
    <div class="auth-container">
      <div class="auth-card">
        <div class="auth-header">
          <h1 class="auth-title">Welcome Back</h1>
          <p class="auth-subtitle">Sign in to view your personalized portfolio</p>
        </div>
        
        <div id="clerk-sign-in" class="clerk-container">
          <div class="clerk-loading">Loading sign-in form...</div>
        </div>
        
        <script>
          (function() {
            const clerkPubKey = document.querySelector('meta[name="clerk-key"]')?.getAttribute('content');
            const container = document.getElementById('clerk-sign-in');
            
            if (!clerkPubKey || clerkPubKey === '') {
              container.innerHTML = '<div class="clerk-error">Authentication not configured. Please contact support.</div>';
              return;
            }
            
            // Load Clerk from CDN
            const script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@latest/dist/clerk.browser.js';
            script.async = true;
            script.onload = function() {
              window.Clerk.load({
                publishableKey: clerkPubKey
              }).then(function(clerk) {
                container.innerHTML = ''; // Clear loading message
                clerk.mountSignIn(container, {
                  redirectUrl: '/portfolio'
                });
              }).catch(function(err) {
                container.innerHTML = '<div class="clerk-error">Failed to load authentication: ' + err.message + '</div>';
              });
            };
            script.onerror = function() {
              container.innerHTML = '<div class="clerk-error">Failed to load authentication service.</div>';
            };
            document.head.appendChild(script);
          })();
        </script>
        
        <div class="auth-footer">
          <p class="auth-text">
            Don't have an account? 
            <a href="/sign-up" class="auth-link">Create one</a>
          </p>
        </div>
      </div>
      
      <div class="auth-info">
        <div class="feature-list">
          <h3 class="feature-title">Track Your Investments</h3>
          <ul class="features">
            <li class="feature-item">
              <span class="feature-icon">📊</span>
              <span class="feature-text">Real-time portfolio tracking with live prices</span>
            </li>
            <li class="feature-item">
              <span class="feature-icon">🔔</span>
              <span class="feature-text">Personalized price alerts</span>
            </li>
            <li class="feature-item">
              <span class="feature-icon">📈</span>
              <span class="feature-text">News with portfolio impact analysis</span>
            </li>
            <li class="feature-item">
              <span class="feature-icon">📅</span>
              <span class="feature-text">Earnings calendar with your positions</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
</Layout>

<style is:global>
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 860px;
  }
  .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
  .logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: var(--text); }
  .logo-sub { font-size: 12px; color: var(--text-3); }
  
  .body { 
    flex: 1; 
    padding: 2rem 1.5rem; 
    max-width: 860px; 
    margin: 0 auto; 
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .auth-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    width: 100%;
    max-width: 800px;
  }
  
  .auth-card {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
  }
  
  .auth-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  
  .auth-title {
    font-size: 24px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  
  .auth-subtitle {
    font-size: 14px;
    color: var(--text-3);
  }
  
  .auth-footer {
    text-align: center;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  
  .auth-text {
    font-size: 14px;
    color: var(--text-2);
  }
  
  .auth-link {
    color: var(--up);
    font-weight: 500;
    text-decoration: none;
  }
  
  .auth-link:hover {
    text-decoration: underline;
  }
  
  .auth-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1rem;
  }
  
  .feature-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 1.5rem;
  }
  
  .features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 14px;
    color: var(--text-2);
  }
  
  .feature-icon {
    font-size: 20px;
  }
  
  /* Clerk customization */
  :global(.clerk-card) {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
  }
  
  :global(.clerk-title) {
    font-size: 0 !important;
  }
  
  :global(.clerk-subtitle) {
    font-size: 0 !important;
  }
  
  :global(.clerk-social-btn) {
    border: 1px solid var(--border) !important;
    border-radius: 4px !important;
    font-size: 14px !important;
  }
  
  :global(.clerk-label) {
    color: var(--text-2) !important;
    font-size: 12px !important;
    text-transform: uppercase !important;
    letter-spacing: 0.06em !important;
  }
  
  :global(.clerk-input) {
    border: 1px solid var(--border) !important;
    border-radius: 4px !important;
    padding: 0.5rem 0.75rem !important;
    font-size: 14px !important;
  }
  
  :global(.clerk-primary-btn) {
    background: var(--up) !important;
    border-radius: 4px !important;
    font-size: 14px !important;
    font-weight: 500 !important;
  }
  
  :global(.clerk-link) {
    color: var(--up) !important;
  }
  
  /* Clerk form container */
  .clerk-container {
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .clerk-loading {
    color: var(--text-3);
    font-size: 14px;
    padding: 2rem;
    text-align: center;
  }
  
  .clerk-error {
    color: var(--down);
    font-size: 14px;
    padding: 2rem;
    text-align: center;
    background: var(--down-bg);
    border: 1px solid var(--down);
    border-radius: 4px;
  }
  
  @media (max-width: 768px) {
    .auth-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .auth-info {
      order: -1;
    }
    
    .feature-list {
      text-align: center;
    }
  }
</style>
