---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  return allNews.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

function getImpactLabel(impact: string) {
  switch (impact) {
    case 'positive': return '▲ Positive';
    case 'negative': return '▼ Negative';
    default: return '→ Neutral';
  }
}
function getImpactClass(impact: string) {
  if (impact === 'positive') return 'up';
  if (impact === 'negative') return 'down';
  return 'neutral';
}

const cls = getImpactClass(entry.data.impact ?? 'neutral');
---

<Layout title={entry.data.title}>
  <div class="page">

    <header class="topbar">
      <a href="/" class="back">← Insider Hub</a>
      <div class="topbar-right">
        <span class="breadcrumb">{entry.data.category === 'macro' ? 'Macro Landscape' : 'Micro & Corporate'}</span>
      </div>
    </header>

    <main class="main">
      <article class="article">

        <!-- Category + impact -->
        <div class="article-meta-top">
          <span class={`impact-badge ${cls}`}>{getImpactLabel(entry.data.impact ?? 'neutral')}</span>
          <span class="cat-badge">{entry.data.category === 'macro' ? 'Macro' : 'Micro'}</span>
          <span class="region-badge">{entry.data.region}</span>
        </div>

        <h1 class="article-title">{entry.data.title}</h1>

        <!-- Meta row -->
        <div class="meta-row">
          <div class="meta-group">
            <span class="meta-label">Source</span>
            {entry.data.url
              ? <a href={entry.data.url} target="_blank" rel="noopener noreferrer" class="meta-link">{entry.data.source} ↗</a>
              : <span class="meta-val">{entry.data.source}</span>
            }
          </div>
          <div class="meta-div"></div>
          <div class="meta-group">
            <span class="meta-label">Published</span>
            <span class="meta-val">
              {new Date(entry.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' })}
            </span>
          </div>
          {entry.data.tickers && entry.data.tickers.length > 0 && (
            <>
              <div class="meta-div"></div>
              <div class="meta-group">
                <span class="meta-label">Tickers</span>
                <div class="tickers">
                  {entry.data.tickers.map(t => <span class="chip">{t}</span>)}
                </div>
              </div>
            </>
          )}
        </div>

        <div class="article-body">
          <Content />
        </div>
      </article>
    </main>

    <footer class="footer">
      <span>Insider Hub</span>
      <span class="footer-sep">·</span>
      <span>Built by Elesis</span>
    </footer>
  </div>
</Layout>

<style>
  .page { min-height: 100vh; display: flex; flex-direction: column; }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.75rem;
    height: 48px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .back {
    font-size: 13px;
    color: var(--text-2);
    transition: color 0.15s;
  }
  .back:hover { color: var(--text); }
  .breadcrumb { font-size: 12px; color: var(--text-3); }

  .main { flex: 1; padding: 2rem 1.5rem; display: flex; justify-content: center; }
  .article { max-width: 740px; width: 100%; }

  /* Badges */
  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .impact-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    letter-spacing: 0.03em;
  }
  .impact-badge.up      { color: var(--up);    background: var(--up-bg); }
  .impact-badge.down    { color: var(--down);  background: var(--down-bg); }
  .impact-badge.neutral { color: var(--text-3); background: var(--bg-subtle); }

  .cat-badge, .region-badge {
    font-size: 11px;
    color: var(--text-3);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
  }

  .article-title {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.01em;
    margin-bottom: 1.25rem;
    color: var(--text);
  }

  /* Meta row */
  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.75rem 1rem;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-left: 3px solid var(--border);
    margin-bottom: 2rem;
    border-radius: 2px;
  }
  .meta-group { display: flex; align-items: center; gap: 0.375rem; }
  .meta-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-3); }
  .meta-val   { font-size: 13px; color: var(--text); }
  .meta-link  { font-size: 13px; color: var(--amber); transition: opacity 0.15s; }
  .meta-link:hover { opacity: 0.7; }
  .meta-div   { width: 1px; height: 14px; background: var(--border); }

  .tickers { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .chip {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--up);
    background: var(--up-bg);
    border: 1px solid rgba(26,110,60,0.2);
    padding: 0 0.375rem;
    border-radius: 2px;
  }

  /* Body content */
  .article-body {
    border-top: 1px solid var(--border);
    padding-top: 1.75rem;
  }

  .article-body :global(h2) {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin: 1.75rem 0 0.625rem;
  }
  .article-body :global(p) {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1rem;
  }
  .article-body :global(li) {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.7;
    margin-bottom: 0.3rem;
  }
  .article-body :global(strong) { color: var(--text); font-weight: 600; }
  .article-body :global(a) {
    color: var(--amber);
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .article-body :global(a:hover) { border-color: var(--amber); }
  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.75rem 0;
  }

  .footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 1.75rem;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-3);
  }
  .footer-sep { color: var(--border); }
</style>
