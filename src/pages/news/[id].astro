---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  return allNews.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

function getImpactColor(impact: string) {
  switch (impact) {
    case 'positive': return '#00d084';
    case 'negative': return '#ff4757';
    default: return '#6b7280';
  }
}

function getImpactLabel(impact: string) {
  switch (impact) {
    case 'positive': return '▲ Positive';
    case 'negative': return '▼ Negative';
    default: return '→ Neutral';
  }
}

const impactColor = getImpactColor(entry.data.impact ?? 'neutral');
---

<Layout title={entry.data.title}>
  <main style="padding: 1rem; max-width: 800px; margin: 0 auto;">

    <!-- Back -->
    <a href="/" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--text-muted); font-size: 0.875rem; text-decoration: none; margin-bottom: 1.5rem;">
      ← Back to Insider Hub
    </a>

    <!-- Article Header -->
    <article>
      <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; flex-wrap: wrap;">
        <span style={`font-size: 0.75rem; font-weight: 600; color: ${impactColor}; background: ${impactColor}22; padding: 0.25rem 0.625rem; border-radius: 9999px;`}>
          {getImpactLabel(entry.data.impact ?? 'neutral')}
        </span>
        <span style="font-size: 0.75rem; background: var(--surface); border: 1px solid var(--border); padding: 0.25rem 0.625rem; border-radius: 9999px; color: var(--text-muted);">
          {entry.data.category === 'macro' ? '🌐 Macro' : '📊 Micro'}
        </span>
        <span style="font-size: 0.75rem; color: var(--text-muted);">{entry.data.region}</span>
      </div>

      <h1 style="font-size: 1.5rem; font-weight: 700; color: var(--text); line-height: 1.4; margin-bottom: 1rem;">
        {entry.data.title}
      </h1>

      <!-- Meta -->
      <div style="display: flex; align-items: center; gap: 1rem; padding: 0.75rem 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 0.375rem;">
          <span style="font-size: 0.75rem; color: var(--text-muted);">Source:</span>
          {entry.data.url
            ? <a href={entry.data.url} target="_blank" rel="noopener noreferrer" style="font-size: 0.875rem; font-weight: 500; color: var(--accent-blue); text-decoration: none;">{entry.data.source} ↗</a>
            : <span style="font-size: 0.875rem; font-weight: 500; color: var(--text);">{entry.data.source}</span>
          }
        </div>
        <span style="color: var(--border);">|</span>
        <div>
          <span style="font-size: 0.75rem; color: var(--text-muted);">Published: </span>
          <span style="font-size: 0.875rem; color: var(--text);">{new Date(entry.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
        </div>
        {entry.data.tickers && entry.data.tickers.length > 0 && (
          <>
            <span style="color: var(--border);">|</span>
            <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
              {entry.data.tickers.map(ticker => (
                <span style="font-size: 0.75rem; background: rgba(0, 208, 132, 0.2); color: var(--accent-green); padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-weight: 600;">${ticker}</span>
              ))}
            </div>
          </>
        )}
      </div>

      <!-- Content -->
      <div class="article-content">
        <Content />
      </div>
    </article>

    <!-- Footer -->
    <footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); text-align: center; font-size: 0.75rem; color: var(--text-muted);">
      Insider Hub • Built by Elesis 💻
    </footer>
  </main>
</Layout>

<style is:global>
  .article-content h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.5rem 0 0.75rem;
  }
  .article-content p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .article-content ul, .article-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .article-content li {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 0.375rem;
  }
  .article-content strong {
    color: var(--text);
    font-weight: 600;
  }
  .article-content a {
    color: var(--accent-blue);
    text-decoration: none;
  }
  .article-content a:hover {
    text-decoration: underline;
  }
  .article-content hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.5rem 0;
  }
</style>
