---
import Layout from '../../layouts/Layout.astro';
import { SignedIn, SignedOut } from '@clerk/astro/components';
import { addPortfolio, getDB } from '../../lib/db';

// Get auth from Clerk middleware
const { userId } = Astro.locals.auth;
if (!userId) {
  return Astro.redirect('/sign-in');
}

// Handle form submission
let error = '';
let success = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const ticker = formData.get('ticker')?.toString().toUpperCase();
    const name = formData.get('name')?.toString();
    const sector = formData.get('sector')?.toString();
    const lots = parseInt(formData.get('lots')?.toString() || '0');
    const avg_price = parseFloat(formData.get('avg_price')?.toString() || '0');
    const conviction = formData.get('conviction')?.toString() || 'HOLD';
    const notes = formData.get('notes')?.toString();
    
    if (!ticker || !name || !sector || lots <= 0 || avg_price <= 0) {
      error = 'Please fill in all required fields';
    } else if (Astro.locals.runtime?.env?.DB) {
      const db = getDB(Astro.locals.runtime.env);
      if (db) {
        const result = await addPortfolio(db, userId, {
          ticker,
          name,
          sector,
          lots,
          avg_price,
          conviction,
          notes
        });
        if (result.success) {
          success = 'Position added successfully!';
        } else {
          error = result.error || 'Failed to add position';
        }
      } else {
        error = 'Database not available';
      }
    } else {
      error = 'Database not available';
    }
  } catch (e) {
    error = e instanceof Error ? e.message : 'Failed to add position';
  }
}
---

<Layout title="Add Position — Insider Hub">
<div class="page">
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="logo">Insider Hub</a>
        <span class="logo-sub">Add Position</span>
      </div>
      <nav class="topbar-nav">
        <a href="/portfolio" class="nav-link">← Back to Portfolio</a>
      </nav>
    </div>
  </header>

  <div class="body">
    <div class="form-container">
      <h1 class="page-title">Add New Position</h1>
      <p class="page-desc">Add a stock to your portfolio to track live prices and P&L</p>
      
      {error && <div class="alert error">{error}</div>}
      {success && <div class="alert success">{success}</div>}
      
      <form method="POST" class="position-form">
        <div class="form-grid">
          <div class="form-group">
            <label for="ticker">Ticker Symbol *</label>
            <input type="text" id="ticker" name="ticker" placeholder="e.g. PTPS" required maxlength="10" />
          </div>
          
          <div class="form-group">
            <label for="name">Company Name *</label>
            <input type="text" id="name" name="name" placeholder="e.g. PT Pulau Subur Tbk" required />
          </div>
          
          <div class="form-group">
            <label for="sector">Sector *</label>
            <select id="sector" name="sector" required>
              <option value="">Select sector...</option>
              <option value="CPO/Plantation">CPO / Plantation</option>
              <option value="Coal">Coal</option>
              <option value="Geothermal/Energy">Geothermal / Energy</option>
              <option value="Ammonia/Chemical">Ammonia / Chemical</option>
              <option value="Nickel/Mining">Nickel / Mining</option>
              <option value="Banking">Banking</option>
              <option value="Telecom">Telecom</option>
              <option value="Other">Other</option>
            </select>
          </div>
          
          <div class="form-group">
            <label for="lots">Number of Lots *</label>
            <input type="number" id="lots" name="lots" placeholder="e.g. 1000" required min="1" />
            <span class="hint">1 lot = 100 shares</span>
          </div>
          
          <div class="form-group">
            <label for="avg_price">Average Price (Rp) *</label>
            <input type="number" id="avg_price" name="avg_price" placeholder="e.g. 191" required min="1" />
          </div>
          
          <div class="form-group">
            <label for="conviction">Conviction Level</label>
            <select id="conviction" name="conviction">
              <option value="HOLD">HOLD</option>
              <option value="CORE">CORE</option>
              <option value="HIGH">HIGH</option>
              <option value="SPEC">SPECULATIVE</option>
            </select>
          </div>
        </div>
        
        <div class="form-group full">
          <label for="notes">Notes / Thesis</label>
          <textarea id="notes" name="notes" rows="3" placeholder="Why this position? What's your thesis?"></textarea>
        </div>
        
        <div class="form-actions">
          <a href="/portfolio" class="btn secondary">Cancel</a>
          <button type="submit" class="btn primary">Add Position</button>
        </div>
      </form>
      
      <div class="help-text">
        <p>💡 <strong>Tip:</strong> Your average price should include all fees (brokerage, etc.) for accurate P&L tracking.</p>
      </div>
    </div>
  </div>
</div>
</Layout>

<style is:global>
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 860px;
  }
  .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
  .logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: var(--text); text-decoration: none; }
  .logo-sub { font-size: 12px; color: var(--text-3); }
  .topbar-nav { display: flex; gap: 0.75rem; }
  .nav-link {
    font-size: 12px; color: var(--text-3); text-decoration: none;
    border: 1px solid var(--border); padding: 2px 8px; border-radius: 4px;
  }
  .nav-link:hover { color: var(--text); border-color: var(--up); }
  
  .body { flex: 1; padding: 2rem 1.5rem; max-width: 860px; margin: 0 auto; width: 100%; }
  
  .form-container {
    max-width: 600px;
    margin: 0 auto;
  }
  .page-title {
    font-size: 24px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .page-desc {
    font-size: 14px;
    color: var(--text-3);
    margin-bottom: 2rem;
  }
  
  .alert {
    padding: 0.75rem 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    font-size: 14px;
  }
  .alert.error {
    background: var(--down-bg);
    border: 1px solid rgba(181,40,40,0.3);
    color: var(--down);
  }
  .alert.success {
    background: var(--up-bg);
    border: 1px solid rgba(26,110,60,0.3);
    color: var(--up);
  }
  
  .position-form {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .form-group.full {
    grid-column: 1 / -1;
  }
  .form-group label {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-2);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 14px;
    background: var(--bg);
    color: var(--text);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--up);
  }
  .form-group .hint {
    font-size: 11px;
    color: var(--text-3);
  }
  
  .form-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-end;
    padding-top: 1rem;
    border-top: 1px solid var(--border-soft);
  }
  .btn {
    font-size: 14px;
    font-weight: 500;
    padding: 0.625rem 1.25rem;
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
  }
  .btn.primary {
    background: var(--up);
    color: white;
    border: 1px solid var(--up);
  }
  .btn.primary:hover {
    background: #166534;
  }
  .btn.secondary {
    background: var(--bg);
    color: var(--text-2);
    border: 1px solid var(--border);
  }
  .btn.secondary:hover {
    background: var(--bg-subtle);
  }
  
  .help-text {
    background: var(--amber-bg);
    border: 1px solid rgba(122,92,30,0.2);
    border-radius: 4px;
    padding: 1rem;
    font-size: 13px;
    color: var(--amber);
  }
  
  @media (max-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
    .form-actions {
      flex-direction: column-reverse;
    }
    .btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
</Layout>
