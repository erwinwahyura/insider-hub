---
import Layout from '../layouts/Layout.astro';

// Clerk hosted page URL - correct format
const clerkInstance = 'beloved-macaque-99';
const redirectUrl = 'https://stocks.erwarx.com/portfolio';
const signUpUrl = `https://${clerkInstance}.accounts.dev/sign-up?redirect_url=${encodeURIComponent(redirectUrl)}`;
---

<Layout title="Sign Up — Insider Hub">
<meta http-equiv="refresh" content={`0; url=${signUpUrl}`} />

<div class="page">
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="logo">Insider Hub</a>
        <span class="logo-sub">Portfolio Tracker</span>
      </div>
    </div>
  </header>

  <div class="body">
    <div class="auth-container">
      <div class="auth-card">
        <div class="auth-header">
          <h1 class="auth-title">Redirecting...</h1>
          <p class="auth-subtitle">Taking you to secure sign-up</p>
        </div>
        
        <div class="redirect-box">
          <p>If not redirected automatically, click below:</p>
          <a href={signUpUrl} class="redirect-btn">
            Sign Up with Clerk
          </a>
        </div>
        
        <div class="auth-footer">
          <p class="auth-text">
            Already have an account? 
            <a href="/sign-in" class="auth-link">Sign in</a>
          </p>
        </div>
      </div>
      
      <div class="auth-info">
        <div class="feature-list">
          <h3 class="feature-title">Why Join?</h3>
          <ul class="features">
            <li class="feature-item">
              <span class="feature-icon">🎯</span>
              <span class="feature-text">Personalized price alerts for your stocks</span>
            </li>
            <li class="feature-item">
              <span class="feature-icon">📊</span>
              <span class="feature-text">Track P&L in real-time with live prices</span>
            </li>
            <li class="feature-item">
              <span class="feature-icon">📰</span>
              <span class="feature-text">News tailored to your portfolio holdings</span>
            </li>
            <li class="feature-item">
              <span class="feature-icon">💡</span>
              <span class="feature-text">Earnings calendar with your positions</span>
            </li>
            <li class="feature-item">
              <span class="feature-icon">🔒</span>
              <span class="feature-text">Secure & private — your data is yours</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
</Layout>

<style is:global>
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 860px;
  }
  .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
  .logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: var(--text); text-decoration: none; }
  .logo-sub { font-size: 12px; color: var(--text-3); }
  
  .body { 
    flex: 1; 
    padding: 2rem 1.5rem; 
    max-width: 860px; 
    margin: 0 auto; 
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .auth-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    width: 100%;
    max-width: 800px;
  }
  
  .auth-card {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
    text-align: center;
  }
  
  .auth-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  
  .auth-title {
    font-size: 24px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  
  .auth-subtitle {
    font-size: 14px;
    color: var(--text-3);
  }
  
  .redirect-box {
    padding: 2rem;
    background: var(--bg-subtle);
    border-radius: 4px;
    margin: 1.5rem 0;
  }
  
  .redirect-box p {
    font-size: 14px;
    color: var(--text-2);
    margin-bottom: 1rem;
  }
  
  .redirect-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--up);
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 500;
    font-size: 14px;
  }
  
  .redirect-btn:hover {
    background: #166534;
  }
  
  .auth-footer {
    text-align: center;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  
  .auth-text {
    font-size: 14px;
    color: var(--text-2);
  }
  
  .auth-link {
    color: var(--up);
    font-weight: 500;
    text-decoration: none;
  }
  
  .auth-link:hover {
    text-decoration: underline;
  }
  
  .auth-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1rem;
  }
  
  .feature-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 1.5rem;
  }
  
  .features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 14px;
    color: var(--text-2);
  }
  
  .feature-icon {
    font-size: 20px;
  }
  
  @media (max-width: 768px) {
    .auth-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .auth-info {
      order: -1;
    }
    
    .feature-list {
      text-align: center;
    }
  }
</style>
</Layout>
