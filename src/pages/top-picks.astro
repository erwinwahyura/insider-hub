---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');

// Calculate ticker mentions and sentiment from news
const tickerStats: Record<string, { mentions: number; bullish: number; bearish: number; neutral: number }> = {};
allNews.forEach(news => {
  const tickers = news.data.tickers || [];
  const impact = news.data.impact || 'neutral';
  tickers.forEach(ticker => {
    if (!tickerStats[ticker]) {
      tickerStats[ticker] = { mentions: 0, bullish: 0, bearish: 0, neutral: 0 };
    }
    tickerStats[ticker].mentions++;
    if (impact === 'positive') tickerStats[ticker].bullish++;
    else if (impact === 'negative') tickerStats[ticker].bearish++;
    else tickerStats[ticker].neutral++;
  });
});

// Top picks data - curated by Elesis based on Om Obet framework
const topPicks = [
  {
    ticker: 'ISSP',
    name: 'Surya Semesta Internusa',
    sector: 'Construction/Property',
    score: 7.5,
    status: 'BUY',
    statusColor: 'up',
    metrics: { per: 5.95, pbv: 0.61, peg: 0.93, de: 0.42, roe: 12.4 },
    catalysts: ['Unit 7 capex', 'Insider buying', 'Infrastructure tailwinds'],
    risk: 'Execution risk on capex timing',
    conviction: 'HIGH',
    allocation: '20% of portfolio',
    notes: 'Om Obet: LULUS. Best redeployment target from ESSA exit.'
  },
  {
    ticker: 'ELSA',
    name: 'Elnusa',
    sector: 'Energy Services',
    score: 8.0,
    status: 'WAIT',
    statusColor: 'warn',
    metrics: { per: 7.52, pbv: 0.85, peg: 0.78, de: 0.31, roe: 14.2 },
    catalysts: ['PER < 8 attractively cheap', 'Energy transition beneficiary'],
    risk: 'BPK audit fraud findings - governance red flag',
    conviction: 'MEDIUM',
    allocation: 'Hold cash allocation',
    notes: 'Governance override. Wait for BPK clarity before entry.'
  },
  {
    ticker: 'ADRO',
    name: 'Adaro Energy',
    sector: 'Coal / Energy Transition',
    score: 7.2,
    status: 'HOLD',
    statusColor: 'neutral',
    metrics: { per: 8.12, pbv: 1.15, peg: 1.2, de: 0.55, roe: 15.8 },
    catalysts: ['Coal price support', 'Green energy pivot', 'Strong cash flows'],
    risk: 'Thermal coal demand decline long-term',
    conviction: 'MEDIUM',
    allocation: 'Optional dividend play',
    notes: 'Solid but not exceptional. Better opportunities elsewhere.'
  },
  {
    ticker: 'ITMG',
    name: 'Indo Tambangraya Megah',
    sector: 'Coal Mining',
    score: 7.0,
    status: 'CYCLICAL',
    statusColor: 'down',
    metrics: { per: 6.48, pbv: 0.92, peg: 1.1, de: 0.28, roe: 18.5 },
    catalysts: ['High dividend yield 13.83%', 'Low debt', 'China demand'],
    risk: 'Laba -71% YoY, payout 118% unsustainable',
    conviction: 'LOW',
    allocation: 'Optional 5-10%',
    notes: 'Geopolitik play only. Cyclical risk too high for core holding.'
  },
  {
    ticker: 'ESSA',
    name: 'Eagle Sejahtera (ESSA)',
    sector: 'Stainless Steel',
    score: 6.5,
    status: 'EXIT',
    statusColor: 'down',
    metrics: { per: 12.4, pbv: 1.35, peg: 1.8, de: 0.62, roe: 9.2 },
    catalysts: ['Nickel price correlation', 'Stainless demand'],
    risk: 'Underwater position, better redeployment targets',
    conviction: 'EXIT',
    allocation: 'SELL 50-70%',
    notes: 'Exit at 690-695, redeploy to ISSP. Holding destroys value.'
  },
  {
    ticker: 'BBRI',
    name: 'Bank Rakyat Indonesia',
    sector: 'Banking',
    score: 7.8,
    status: 'WATCH',
    statusColor: 'neutral',
    metrics: { per: 11.2, pbv: 1.85, peg: 1.05, de: null, roe: 18.2 },
    catalysts: ['NIM expansion', 'Microloan growth', 'BI rate plateau'],
    risk: 'Credit cycle, operational inefficiency',
    conviction: 'MEDIUM',
    allocation: 'Banking allocation',
    notes: 'Best bank play when financials rotate. Watch for entry.'
  }
];

// Sort by score descending
const sortedPicks = topPicks.sort((a, b) => b.score - a.score);

// Get recent news for each pick
const picksWithNews = sortedPicks.map(pick => {
  const news = allNews
    .filter(n => (n.data.tickers || []).includes(pick.ticker))
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 3);
  return { ...pick, recentNews: news };
});

function impactClass(impact: string) {
  if (impact === 'positive') return 'up';
  if (impact === 'negative') return 'down';
  return 'neutral';
}

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}
---

<Layout title="Top Picks — Insider Hub">
<div class="page">

  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="logo">Insider Hub</a>
        <span class="logo-sub">Curated Top Picks</span>
        <span class="private-badge">Private</span>
      </div>
      <button class="mobile-menu-btn" aria-label="Menu" id="menuBtn">
        <span></span><span></span><span></span>
      </button>
      <nav class="topbar-nav" id="mainNav">
        <a href="/" class="nav-link">News</a>
        <a href="/portfolio" class="nav-link">Portfolio</a>
        <a href="/daily-summary" class="nav-link">Summary</a>
      </nav>
    </div>
  </header>

  <div class="body">

    <!-- Header -->
    <section class="intro">
      <h1 class="page-title">Top Picks</h1>
      <p class="page-sub">Curated by Elesis • Om Obet Framework • Updated April 2026</p>
      <div class="methodology">
        <span class="method-tag">PER &lt; 10</span>
        <span class="method-tag">PBV &lt; 1.5</span>
        <span class="method-tag">D/E &lt; 0.5</span>
        <span class="method-tag">ROE &gt; 10%</span>
        <span class="method-tag">Governance ✅</span>
      </div>
    </section>

    <!-- Quick Stats -->
    <section class="stats-row">
      <div class="stat up">
        <span class="stat-n">{picksWithNews.filter(p => p.status === 'BUY').length}</span>
        <span class="stat-l">Buy Now</span>
      </div>
      <div class="stat warn">
        <span class="stat-n">{picksWithNews.filter(p => p.status === 'WAIT' || p.status === 'WATCH').length}</span>
        <span class="stat-l">Wait/Watch</span>
      </div>
      <div class="stat down">
        <span class="stat-n">{picksWithNews.filter(p => p.status === 'EXIT').length}</span>
        <span class="stat-l">Exit</span>
      </div>
      <div class="stat">
        <span class="stat-n">{picksWithNews.filter(p => p.conviction === 'HIGH').length}</span>
        <span class="stat-l">High Conviction</span>
      </div>
    </section>

    <!-- Priority Actions -->
    <section class="priority-banner">
      <div class="priority-content">
        <span class="priority-label">🔥 Priority Action</span>
        <div class="priority-text">
          <strong>ESSA → ISSP</strong>
          <span>Exit ESSA 50-70% at 690-695, redeploy Rp 9-13M to ISSP at ~430s</span>
        </div>
      </div>
    </section>

    <!-- Top Picks Grid -->
    <section class="picks-grid">
      {picksWithNews.map((pick, idx) => (
        <div class={`pick-card ${pick.statusColor}`}>
          <div class="pick-header">
            <div class="pick-rank">#{idx + 1}</div>
            <div class="pick-score">
              <span class="score-val">{pick.score.toFixed(1)}</span>
              <span class="score-lab">/ 10</span>
            </div>
            <span class={`pick-status ${pick.statusColor}`}>{pick.status}</span>
          </div>
          
          <div class="pick-body">
            <div class="pick-ticker-row">
              <span class="pick-ticker">{pick.ticker}</span>
              <span class="pick-name">{pick.name}</span>
            </div>
            <span class="pick-sector">{pick.sector}</span>
            
            <div class="pick-metrics">
              <div class="metric">
                <span class="metric-lab">PER</span>
                <span class={`metric-val ${pick.metrics.per < 10 ? 'good' : pick.metrics.per > 15 ? 'bad' : ''}`}>
                  {pick.metrics.per.toFixed(2)}
                </span>
              </div>
              <div class="metric">
                <span class="metric-lab">PBV</span>
                <span class={`metric-val ${pick.metrics.pbv < 1 ? 'good' : pick.metrics.pbv > 2 ? 'bad' : ''}`}>
                  {pick.metrics.pbv.toFixed(2)}
                </span>
              </div>
              <div class="metric">
                <span class="metric-lab">D/E</span>
                <span class={`metric-val ${pick.metrics.de !== null && pick.metrics.de < 0.5 ? 'good' : pick.metrics.de !== null && pick.metrics.de > 1 ? 'bad' : ''}`}>
                  {pick.metrics.de !== null ? pick.metrics.de.toFixed(2) : 'N/A'}
                </span>
              </div>
              <div class="metric">
                <span class="metric-lab">ROE</span>
                <span class={`metric-val ${pick.metrics.roe > 15 ? 'good' : pick.metrics.roe < 10 ? 'bad' : ''}`}>
                  {pick.metrics.roe.toFixed(1)}%
                </span>
              </div>
            </div>

            <div class="pick-catalysts">
              <span class="cat-label">Catalysts:</span>
              <ul class="cat-list">
                {pick.catalysts.map(cat => <li>{cat}</li>)}
              </ul>
            </div>

            <div class={`pick-risk ${pick.risk.includes('governance') || pick.risk.includes('BPK') ? 'high-risk' : ''}`}>
              <span class="risk-label">⚠️ Risk:</span>
              <span class="risk-text">{pick.risk}</span>
            </div>

            <div class="pick-footer">
              <div class="pick-conv">
                <span class="conv-label">Conviction</span>
                <span class={`conv-val ${pick.conviction.toLowerCase()}`}>{pick.conviction}</span>
              </div>
              <div class="pick-alloc">
                <span class="alloc-label">Suggested</span>
                <span class="alloc-val">{pick.allocation}</span>
              </div>
            </div>

            {pick.notes && (
              <div class="pick-notes">
                <span class="notes-icon">💡</span>
                <span class="notes-text">{pick.notes}</span>
              </div>
            )}

            {pick.recentNews.length > 0 && (
              <div class="pick-news">
                <span class="news-label">Recent mentions:</span>
                <div class="news-chips">
                  {pick.recentNews.map(n => (
                    <a href={`/news/${n.id}`} class={`news-chip ${impactClass(n.data.impact || 'neutral')}`}>
                      {formatDate(n.data.date)} · {n.data.impact === 'positive' ? '▲' : n.data.impact === 'negative' ? '▼' : '→'}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </section>

    <!-- Framework Legend -->
    <section class="legend">
      <h3 class="legend-title">Scoring Methodology</h3>
      <div class="legend-grid">
        <div class="legend-item">
          <span class="legend-score">8.0+</span>
          <span class="legend-desc">Exceptional — High conviction buy</span>
        </div>
        <div class="legend-item">
          <span class="legend-score">7.0-7.9</span>
          <span class="legend-desc">Attractive — Buy on weakness</span>
        </div>
        <div class="legend-item">
          <span class="legend-score">6.0-6.9</span>
          <span class="legend-desc">Fair — Watch for catalyst</span>
        </div>
        <div class="legend-item">
          <span class="legend-score">&lt; 6.0</span>
          <span class="legend-desc">Avoid — Better opportunities</span>
        </div>
      </div>
    </section>

  </div>

  <footer class="footer">
    Insider Hub · Top Picks curated by Elesis 💻 · Last updated April 2026
  </footer>

</div>
</Layout>

<style>
  .page { min-height: 100vh; display: flex; flex-direction: column; }

  /* Topbar */
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 1000px;
  }
  .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
  .topbar-right { display: flex; align-items: center; gap: 0.5rem; }
  .logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .logo-sub { font-size: 12px; color: var(--text-3); }
  .private-badge {
    font-size: 10px; font-weight: 500; color: var(--text-3);
    border: 1px solid var(--border); padding: 1px 6px; border-radius: 3px;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .nav-link {
    font-size: 12px; color: var(--text-3); text-decoration: none;
    border: 1px solid var(--border); padding: 2px 8px; border-radius: 4px;
    transition: all 0.15s;
  }
  .nav-link:hover { color: var(--text); border-color: var(--up); background: var(--up-bg); }

  .topbar-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 32px;
    height: 32px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    padding: 4px;
    gap: 3px;
    margin-left: auto;
  }
  .mobile-menu-btn span {
    display: block;
    width: 14px;
    height: 2px;
    background: var(--text-2);
    border-radius: 1px;
    transition: all 0.2s;
  }
  .mobile-menu-btn.open span:nth-child(1) { transform: rotate(45deg) translate(3px, 3px); }
  .mobile-menu-btn.open span:nth-child(2) { opacity: 0; }
  .mobile-menu-btn.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }

  /* Body */
  .body { flex: 1; padding: 1.25rem 1.5rem; max-width: 1000px; margin: 0 auto; width: 100%; }

  /* Intro */
  .intro { margin-bottom: 1.25rem; }
  .page-title { font-size: 24px; font-weight: 600; margin: 0 0 0.25rem; }
  .page-sub { font-size: 13px; color: var(--text-3); margin: 0 0 0.75rem; }
  .methodology { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .method-tag {
    font-size: 11px; color: var(--text-2); background: var(--bg-subtle);
    border: 1px solid var(--border); padding: 2px 8px; border-radius: 3px;
    font-family: var(--mono);
  }

  /* Stats */
  .stats-row {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
    background: var(--border); border: 1px solid var(--border);
    margin-bottom: 1rem; overflow: hidden;
  }
  .stat {
    background: var(--bg); padding: 0.875rem 1rem;
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .stat-n { font-size: 22px; font-weight: 500; line-height: 1; color: var(--text); }
  .stat-l { font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; }
  .stat.up .stat-n { color: var(--up); }
  .stat.down .stat-n { color: var(--down); }
  .stat.warn .stat-n { color: var(--amber); }

  /* Priority Banner */
  .priority-banner {
    background: linear-gradient(90deg, var(--down-bg) 0%, var(--bg-raised) 100%);
    border: 1px solid var(--down-bg); border-radius: 6px;
    padding: 0.75rem 1rem; margin-bottom: 1rem;
  }
  .priority-content { display: flex; align-items: center; gap: 0.75rem; }
  .priority-label {
    font-size: 11px; font-weight: 600; color: var(--down);
    background: var(--down-bg); padding: 2px 8px; border-radius: 3px;
    white-space: nowrap;
  }
  .priority-text {
    display: flex; flex-direction: column; gap: 0.15rem;
    font-size: 13px; color: var(--text);
  }
  .priority-text strong { font-weight: 600; }
  .priority-text span { font-size: 12px; color: var(--text-2); }

  /* Picks Grid */
  .picks-grid {
    display: grid; grid-template-columns: repeat(1, 1fr); gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) { .picks-grid { grid-template-columns: repeat(2, 1fr); } }

  .pick-card {
    background: var(--bg-raised); border: 1px solid var(--border); border-radius: 8px;
    overflow: hidden; display: flex; flex-direction: column;
  }
  .pick-card.up { border-top: 3px solid var(--up); }
  .pick-card.down { border-top: 3px solid var(--down); }
  .pick-card.warn { border-top: 3px solid var(--amber); }
  .pick-card.neutral { border-top: 3px solid var(--border); }

  .pick-header {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.625rem 0.75rem; background: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
  }
  .pick-rank {
    font-size: 12px; font-weight: 600; color: var(--text-3);
    background: var(--bg); border: 1px solid var(--border);
    padding: 1px 6px; border-radius: 3px;
  }
  .pick-score { display: flex; align-items: baseline; gap: 0.15rem; margin-left: auto; }
  .score-val { font-size: 16px; font-weight: 600; color: var(--text); }
  .score-lab { font-size: 11px; color: var(--text-3); }
  .pick-status {
    font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 3px;
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .pick-status.up { background: var(--up); color: #fff; }
  .pick-status.down { background: var(--down); color: #fff; }
  .pick-status.warn { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber-bg); }
  .pick-status.neutral { background: var(--bg-subtle); color: var(--text-2); }

  .pick-body { padding: 0.75rem; display: flex; flex-direction: column; gap: 0.625rem; flex: 1; }

  .pick-ticker-row { display: flex; align-items: baseline; gap: 0.5rem; }
  .pick-ticker {
    font-size: 18px; font-weight: 600; color: var(--text); font-family: var(--mono);
  }
  .pick-name { font-size: 12px; color: var(--text-2); }
  .pick-sector { font-size: 11px; color: var(--text-3); margin-top: -0.25rem; }

  .pick-metrics {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem;
    background: var(--bg); border: 1px solid var(--border); border-radius: 4px;
    padding: 0.5rem;
  }
  .metric { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }
  .metric-lab { font-size: 10px; color: var(--text-3); text-transform: uppercase; }
  .metric-val { font-size: 12px; font-weight: 500; color: var(--text); font-family: var(--mono); }
  .metric-val.good { color: var(--up); }
  .metric-val.bad { color: var(--down); }

  .pick-catalysts { margin-top: 0.25rem; }
  .cat-label { font-size: 10px; color: var(--text-3); font-weight: 500; text-transform: uppercase; }
  .cat-list { margin: 0.25rem 0 0; padding-left: 1rem; font-size: 12px; color: var(--text-2); }
  .cat-list li { margin-bottom: 0.15rem; }

  .pick-risk {
    background: var(--down-bg); border: 1px solid var(--down-bg);
    padding: 0.5rem; border-radius: 4px; font-size: 11px;
    display: flex; gap: 0.4rem;
  }
  .pick-risk.high-risk {
    background: var(--amber-bg); border-color: var(--amber-bg);
  }
  .risk-label { color: var(--down); font-weight: 600; }
  .pick-risk.high-risk .risk-label { color: var(--amber); }
  .risk-text { color: var(--text-2); }

  .pick-footer {
    display: flex; gap: 1rem; margin-top: auto; padding-top: 0.5rem;
    border-top: 1px solid var(--border-soft);
  }
  .pick-conv, .pick-alloc { display: flex; flex-direction: column; gap: 0.1rem; }
  .conv-label, .alloc-label { font-size: 10px; color: var(--text-3); text-transform: uppercase; }
  .conv-val { font-size: 11px; font-weight: 600; }
  .conv-val.high { color: var(--up); }
  .conv-val.medium { color: var(--amber); }
  .conv-val.low { color: var(--down); }
  .conv-val.exit { color: var(--down); text-decoration: line-through; }
  .alloc-val { font-size: 11px; color: var(--text-2); font-weight: 500; }

  .pick-notes {
    background: var(--up-bg); border: 1px solid var(--up-bg);
    padding: 0.5rem; border-radius: 4px; font-size: 11px;
    display: flex; gap: 0.4rem; color: var(--up);
  }
  .notes-icon { flex-shrink: 0; }
  .notes-text { color: var(--text-2); }

  .pick-news { margin-top: 0.25rem; }
  .news-label { font-size: 10px; color: var(--text-3); }
  .news-chips { display: flex; gap: 0.25rem; flex-wrap: wrap; margin-top: 0.25rem; }
  .news-chip {
    font-size: 10px; padding: 2px 6px; border-radius: 3px; text-decoration: none;
    background: var(--bg-subtle); color: var(--text-2); border: 1px solid var(--border);
  }
  .news-chip:hover { background: var(--bg); }
  .news-chip.up { background: var(--up-bg); color: var(--up); border-color: var(--up-bg); }
  .news-chip.down { background: var(--down-bg); color: var(--down); border-color: var(--down-bg); }

  /* Legend */
  .legend { background: var(--bg-raised); border: 1px solid var(--border); border-radius: 6px; padding: 1rem; }
  .legend-title { font-size: 13px; font-weight: 600; margin: 0 0 0.75rem; }
  .legend-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
  @media (min-width: 640px) { .legend-grid { grid-template-columns: repeat(4, 1fr); } }
  .legend-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .legend-score { font-size: 12px; font-weight: 600; color: var(--text); font-family: var(--mono); }
  .legend-desc { font-size: 11px; color: var(--text-2); }

  /* Footer */
  .footer {
    padding: 1rem 1.5rem; border-top: 1px solid var(--border);
    text-align: center; font-size: 12px; color: var(--text-3);
    background: var(--bg-subtle);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .picks-grid { grid-template-columns: 1fr; }
    .pick-metrics { grid-template-columns: repeat(2, 1fr); }
    .pick-footer { flex-direction: column; gap: 0.5rem; }
  }

  @media (max-width: 768px) {
    .topbar { height: auto; }
    .topbar-inner { 
      flex-wrap: wrap; 
      padding: 0.5rem 0.75rem;
      position: relative;
    }
    .mobile-menu-btn { display: flex; }
    .topbar-nav { 
      display: none; 
      width: 100%; 
