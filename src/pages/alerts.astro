---
import Layout from '../layouts/Layout.astro';
import { SignedIn, SignedOut, UserButton } from '@clerk/astro/components';
import { getUserAlerts, getDB, type PriceAlert } from '../lib/db';

// Get auth from Clerk middleware
const { userId } = Astro.locals.auth;
const isLoggedIn = !!userId;

// Load user-specific alerts from D1
let alerts: PriceAlert[] = [];

if (isLoggedIn && Astro.locals.runtime?.env?.DB) {
  const db = getDB(Astro.locals.runtime.env);
  if (db) {
    try {
      alerts = await getUserAlerts(db, userId);
    } catch (e) {
      console.error('Failed to load alerts from D1:', e);
    }
  }
} else {
  // Demo alerts for non-logged in users
  alerts = [
    { id: 1, user_id: 'demo', ticker: 'PTPS', alert_type: 'price_below', target_price: 175, current_price: 183, message: 'PTPS buy opportunity: Price dropped to {price} (target: {target})', priority: 'high', cooldown_minutes: 60, is_active: true, created_at: new Date().toISOString() },
    { id: 2, user_id: 'demo', ticker: 'PTPS', alert_type: 'price_below', target_price: 150, current_price: 183, message: 'PTPS alert: Price fell to {price} (below {target})', priority: 'critical', cooldown_minutes: 30, is_active: true, created_at: new Date().toISOString() },
    { id: 3, user_id: 'demo', ticker: 'PGEO', alert_type: 'price_below', target_price: 950, current_price: 1020, message: 'PGEO add opportunity', priority: 'medium', cooldown_minutes: 120, is_active: true, created_at: new Date().toISOString() },
  ];
}

// Categorize alerts (is_active is 1/0 in D1 SQLite)
const activeAlerts = alerts.filter(a => a.is_active === true || a.is_active === 1);
const triggeredAlerts = alerts.filter(a => a.last_triggered);

function formatPrice(alert: any) {
  if (alert.unit) return `${alert.current_price} ${alert.unit}`;
  return alert.current_price?.toLocaleString() || '-';
}

function formatTarget(alert: any) {
  if (alert.unit) return `${alert.target_price} ${alert.unit}`;
  return alert.target_price?.toLocaleString() || '-';
}

function progressToTarget(alert: any) {
  if (!alert.current_price || !alert.target_price) return 0;
  
  if (alert.alert_type === 'price_below' || alert.alert_type === 'commodity_below') {
    if (alert.current_price <= alert.target_price) return 100;
    const range = alert.target_price * 0.2;
    const distance = alert.current_price - alert.target_price;
    return Math.max(0, 100 - (distance / range) * 100);
  } else {
    if (alert.current_price >= alert.target_price) return 100;
    const range = alert.target_price * 0.2;
    const distance = alert.target_price - alert.current_price;
    return Math.max(0, 100 - (distance / range) * 100);
  }
}

function priorityColor(priority: string) {
  if (priority === 'critical') return 'critical';
  if (priority === 'high') return 'high';
  if (priority === 'medium') return 'medium';
  return 'low';
}

const lastUpdated = new Date().toISOString();
---

<Layout title={isLoggedIn ? "Your Alerts — Insider Hub" : "Alerts Demo — Insider Hub"}>
<div class="page">
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="logo">Insider Hub</a>
        <span class="logo-sub">{isLoggedIn ? 'Price Alerts' : 'Alerts Demo'}</span>
      </div>
      <nav class="topbar-nav">
        <a href="/" class="nav-link">Home</a>
        <a href="/daily-summary" class="nav-link">Summary</a>
        <a href="/portfolio" class="nav-link">Portfolio</a>
        <a href="/earnings" class="nav-link">Earnings</a>
        <a href="/alerts" class="nav-link active">Alerts</a>
        <a href="/top-picks" class="nav-link">Top Picks</a>
        
        <SignedIn>
          <div class="user-menu">
            <UserButton afterSignOutUrl="/" />
          </div>
        </SignedIn>
        
        <SignedOut>
          <a href="/sign-in" class="nav-link sign-in">Sign In</a>
        </SignedOut>
      </nav>
    </div>
  </header>

  <div class="body">
    <!-- Auth Banner -->
    <SignedOut>
      <div class="auth-banner">
        <div class="auth-banner-content">
          <span class="auth-icon">🔔</span>
          <div class="auth-text">
            <p class="auth-title">Viewing Demo Alerts</p>
            <p class="auth-desc">Sign in to create your own personalized price alerts.</p>
          </div>
          <a href="/sign-in" class="auth-btn">Sign In / Create Account</a>
        </div>
      </div>
    </SignedOut>

    <!-- Status Card -->
    <section class="status-card">
      <div class="status-main">
        <div class={`status-indicator ${activeAlerts.length > 0 ? 'active' : 'inactive'}`}>
          <span class="indicator-dot"></span>
          <span class="status-text">{activeAlerts.length > 0 ? 'Alerts Active' : 'No Active Alerts'}</span>
        </div>
        <div class="status-stats">
          <div class="stat">
            <span class="stat-value">{activeAlerts.length}</span>
            <span class="stat-label">Watching</span>
          </div>
          <div class="stat triggered">
            <span class="stat-value">{triggeredAlerts.length}</span>
            <span class="stat-label">Triggered</span>
          </div>
        </div>
      </div>
      <div class="last-check">
        <span class="mono dim">Last check: {new Date(lastUpdated).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'})}</span>
        <span class="mono dim">Auto-check every 30 min</span>
      </div>
    </section>

    <!-- Active Alerts -->
    {activeAlerts.length > 0 ? (
      <section class="alerts-section">
        <div class="section-head">
          <span class="section-icon">🔔</span>
          <span class="section-title">Active Alerts</span>
          <span class="section-count">{activeAlerts.length}</span>
        </div>
        <div class="alerts-list">
          {activeAlerts.map(alert => {
            const progress = progressToTarget(alert);
            return (
              <div class={`alert-card ${priorityColor(alert.priority)}`}>
                <div class="alert-header">
                  <div class="alert-ticker">
                    <span class="ticker">{alert.ticker}</span>
                    <span class={`priority-badge ${priorityColor(alert.priority)}`}>{alert.priority}</span>
                  </div>
                  <div class="alert-type">
                    {alert.alert_type === 'price_below' && '≤ Target'}
                    {alert.alert_type === 'price_above' && '≥ Target'}
                    {alert.alert_type === 'commodity_below' && '≤ Commodity'}
                    {alert.alert_type === 'commodity_above' && '≥ Commodity'}
                  </div>
                </div>
                <div class="alert-prices">
                  <div class="current">
                    <span class="price-label">Current</span>
                    <span class="price-value mono">{formatPrice(alert)}</span>
                  </div>
                  <div class="arrow">→</div>
                  <div class="target">
                    <span class="price-label">Target</span>
                    <span class="price-value mono target">{formatTarget(alert)}</span>
                  </div>
                </div>
                <div class="progress-bar">
                  <div class="progress-track">
                    <div 
                      class={`progress-fill ${progress >= 100 ? 'complete' : ''}`} 
                      style={`width: ${Math.min(progress, 100)}%`}
                    ></div>
                  </div>
                  <span class="progress-text">{progress >= 100 ? 'Ready to trigger!' : `${Math.round(progress)}% to target`}</span>
                </div>
                <div class="alert-message">{alert.message.replace('{price}', formatPrice(alert)).replace('{target}', formatTarget(alert))}</div>
                <div class="alert-meta">
                  <span class="cooldown">Cooldown: {alert.cooldown_minutes} min</span>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    ) : (
      <section class="empty-state">
        <div class="empty-icon">🔔</div>
        <p class="empty-title">No alerts yet</p>
        <p class="empty-desc">Create your first price alert to get notified when stocks hit your target prices.</p>
        <SignedIn>
          <a href="/alerts/add" class="empty-btn">Create Alert</a>
        </SignedIn>
        <SignedOut>
          <a href="/sign-in" class="empty-btn">Sign In to Create Alerts</a>
        </SignedOut>
      </section>
    )}

    <!-- Triggered Alerts -->
    {triggeredAlerts.length > 0 && (
      <section class="alerts-section triggered">
        <div class="section-head">
          <span class="section-icon">🔥</span>
          <span class="section-title">Recently Triggered</span>
          <span class="section-count">{triggeredAlerts.length}</span>
        </div>
        <div class="alerts-list compact">
          {triggeredAlerts.map(alert => (
            <div class="alert-card compact triggered">
              <div class="alert-row">
                <span class="ticker">{alert.ticker}</span>
                <span class="trigger-status">⚡ Triggered</span>
                <span class="mono">{alert.current_price?.toLocaleString()}</span>
                <span class="mono dim">Target: {alert.target_price?.toLocaleString()}</span>
                {alert.last_triggered && (
                  <span class="time mono dim">{new Date(alert.last_triggered).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'})}</span>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Quick Links -->
    <section class="actions-panel">
      <div class="panel-head">
        <span class="panel-title">Quick Links</span>
      </div>
      <div class="links-grid">
        <a href="/portfolio" class="link-btn">
          <span class="link-icon">📊</span>
          <span class="link-label">View Portfolio</span>
        </a>
        <a href="/" class="link-btn">
          <span class="link-icon">📰</span>
          <span class="link-label">Latest News</span>
        </a>
        <a href="/earnings" class="link-btn">
          <span class="link-icon">📅</span>
          <span class="link-label">Earnings Calendar</span>
        </a>
      </div>
    </section>
  </div>

  <footer class="footer">
    Insider Hub · {isLoggedIn ? 'Push notifications enabled' : 'Sign in to enable personalized alerts'}
  </footer>
</div>
</Layout>

<style is:global>
  .page { min-height: 100vh; display: flex; flex-direction: column; }
  
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 860px;
  }
  .topbar-left { display: flex; align-items: center; gap: 0.75rem; }
  .logo { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; color: var(--text); text-decoration: none; }
  .logo-sub { font-size: 12px; color: var(--text-3); }
  .topbar-nav {
    display: flex; align-items: center; gap: 0.75rem;
  }
  .nav-link {
    font-size: 12px; color: var(--text-3); text-decoration: none;
    border: 1px solid var(--border); padding: 2px 8px; border-radius: 4px;
    transition: all 0.15s;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--text); border-color: var(--up); background: rgba(26,110,60,0.05);
  }
  .nav-link.sign-in {
    background: var(--up); color: white; border-color: var(--up);
  }
  .user-menu { margin-left: 0.5rem; }
  .user-menu :global(.cl-userButton-root) { width: 32px; height: 32px; }
  
  .mono { font-family: var(--mono); }
  .dim { color: var(--text-3); }
  
  .body { flex: 1; padding: 1.25rem 1.5rem; max-width: 860px; margin: 0 auto; width: 100%; }

  /* Auth Banner */
  .auth-banner {
    background: linear-gradient(135deg, var(--up-bg) 0%, #e0f2e9 100%);
    border: 1px solid rgba(26,110,60,0.2);
    border-radius: 8px;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
  }
  .auth-banner-content {
    display: flex; align-items: center;
    gap: 1rem;
  }
  .auth-icon { font-size: 28px; }
  .auth-text { flex: 1; }
  .auth-title { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 0.25rem; }
  .auth-desc { font-size: 13px; color: var(--text-2); }
  .auth-btn {
    font-size: 13px; font-weight: 500; color: white;
    background: var(--up); padding: 0.5rem 1rem;
    border-radius: 4px; text-decoration: none; white-space: nowrap;
  }
  .auth-btn:hover { background: #166534; }

  /* Status */
  .status-card {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1rem;
    margin-bottom: 1.5rem;
  }
  .status-main {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 0.75rem;
  }
  .status-indicator {
    display: flex; align-items: center; gap: 0.5rem;
  }
  .indicator-dot {
    width: 10px; height: 10px;
    border-radius: 50%; background: var(--border);
  }
  .status-indicator.active .indicator-dot {
    background: var(--up); animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .status-text { font-size: 14px; font-weight: 500; color: var(--text); }
  .status-stats { display: flex; gap: 1.5rem; }
  .stat { text-align: center; }
  .stat-value { display: block; font-size: 20px; font-weight: 500; color: var(--text); font-family: var(--mono); }
  .stat.triggered .stat-value { color: var(--amber); }
  .stat-label { font-size: 11px; color: var(--text-3); text-transform: uppercase; }
  .last-check { display: flex; justify-content: space-between;
    padding-top: 0.75rem; border-top: 1px solid var(--border-soft); font-size: 11px;
  }

  /* Alerts */
  .alerts-section { margin-bottom: 1.5rem; }
  .section-head {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 0; border-bottom: 1px solid var(--border); margin-bottom: 1rem;
  }
  .section-icon { font-size: 16px; }
  .section-title { font-size: 14px; font-weight: 600; color: var(--text); text-transform: uppercase; letter-spacing: 0.06em; }
  .section-count { margin-left: auto; font-size: 12px; color: var(--text-3); background: var(--bg-subtle); padding: 2px 8px; border-radius: 3px; }

  .alerts-list { display: flex; flex-direction: column; gap: 1rem; }

  .alert-card {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1rem;
    border-left: 3px solid var(--border);
  }
  .alert-card.critical { border-left-color: var(--down); }
  .alert-card.high { border-left-color: var(--amber); }
  .alert-card.medium { border-left-color: #3b82f6; }
  .alert-card.low { border-left-color: var(--text-3); }

  .alert-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
  .alert-ticker { display: flex; align-items: center; gap: 0.5rem; }
  .ticker { font-size: 16px; font-weight: 600; color: var(--text); font-family: var(--mono); }
  .priority-badge {
    font-size: 9px; padding: 1px 6px;
    border-radius: 2px; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600;
  }
  .priority-badge.critical { background: var(--down-bg); color: var(--down); border: 1px solid var(--down); }
  .priority-badge.high { background: var(--amber-bg); color: var(--amber); border: 1px solid var(--amber); }
  .priority-badge.medium { background: var(--bg-subtle); color: var(--text-2); border: 1px solid var(--border); }

  .alert-prices { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
  .current, .target { display: flex; flex-direction: column; gap: 0.1rem; }
  .price-label { font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.04em; }
  .price-value { font-size: 20px; font-weight: 500; color: var(--text); }
  .price-value.target { color: var(--amber); }
  .arrow { color: var(--text-3); font-size: 14px; }

  .progress-bar { margin-bottom: 0.75rem; }
  .progress-track { height: 6px; background: var(--bg-subtle); border-radius: 3px; overflow: hidden; margin-bottom: 0.375rem; }
  .progress-fill { height: 100%; background: var(--amber); border-radius: 3px; transition: width 0.3s; }
  .progress-fill.complete { background: var(--up); animation: pulse 1s infinite; }
  .progress-text { font-size: 11px; color: var(--text-3); }

  .alert-message {
    font-size: 12px; color: var(--text-2);
    background: var(--bg-subtle); padding: 0.5rem 0.75rem;
    border-radius: 3px; margin-bottom: 0.5rem;
  }
  .alert-meta { display: flex; justify-content: space-between; align-items: center; font-size: 11px; color: var(--text-3); }

  /* Empty State */
  .empty-state {
    display: flex; flex-direction: column; align-items: center;
    padding: 3rem 2rem; text-align: center;
    background: var(--bg-raised); border: 1px solid var(--border);
    border-radius: 8px; margin-bottom: 1.5rem;
  }
  .empty-icon { font-size: 48px; margin-bottom: 1rem; opacity: 0.5; }
  .empty-title { font-size: 18px; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; }
  .empty-desc { font-size: 14px; color: var(--text-3); margin-bottom: 1.5rem; }
  .empty-btn { font-size: 14px; font-weight: 500; color: white; background: var(--up); padding: 0.625rem 1.25rem; border-radius: 4px; text-decoration: none; }
  .empty-btn:hover { background: #166534; }

  /* Actions */
  .actions-panel {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .panel-head { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-bottom: 1px solid var(--border); background: var(--bg-subtle); }
  .panel-title { font-size: 12px; font-weight: 600; color: var(--text); text-transform: uppercase; letter-spacing: 0.06em; }
  .links-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); }
  .link-btn { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; padding: 1.5rem 1rem; background: var(--bg-raised); text-decoration: none; color: inherit; transition: background 0.15s; }
  .link-btn:hover { background: var(--bg-subtle); }
  .link-icon { font-size: 24px; }
  .link-label { font-size: 12px; color: var(--text-2); }

  .footer { padding: 1rem 1.5rem; border-top: 1px solid var(--border); text-align: center; font-size: 12px; color: var(--text-3); background: var(--bg-subtle); }

  @media (max-width: 768px) {
    .auth-banner-content { flex-direction: column; text-align: center; }
    .alert-prices { flex-direction: column; align-items: flex-start; }
    .arrow { transform: rotate(90deg); }
    .links-grid { grid-template-columns: 1fr; }
  }
</style>
</Layout>
