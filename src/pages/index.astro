---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTickers = [...new Set(sortedNews.flatMap(n => n.data.tickers || []))].sort();
const ITEMS_PER_PAGE = 10;
const totalPages = Math.ceil(sortedNews.length / ITEMS_PER_PAGE);

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMins = Math.floor((now.getTime() - date.getTime()) / 60000);
  const diffHrs = Math.floor(diffMins / 60);
  if (diffMins < 60) return `${diffMins}m ago`;
  if (diffHrs < 24) return `${diffHrs}h ago`;
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}

function impactClass(impact: string) {
  if (impact === 'positive') return 'up';
  if (impact === 'negative') return 'down';
  return 'neutral';
}
---

<Layout title="Insider Hub — Indonesia Market Intelligence">
<div class="page">

  <!-- Top bar -->
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <span class="logo">Insider Hub</span>
        <span class="logo-sub">Indonesia Market Intelligence</span>
        <span class="private-badge">Private</span>
      </div>
      <div class="topbar-right">
        <span class="mono dim">{sortedNews.length} articles</span>
        <span class="dim">Updated {formatDate(sortedNews[0]?.data.date || new Date().toISOString())}</span>
      </div>
    </div>
  </header>

  <div class="body">

    <!-- Stats -->
    <section class="stats-row">
      <div class="stat up">
        <span class="stat-n mono">{sortedNews.filter(n => n.data.impact === 'positive').length}</span>
        <span class="stat-l">Bullish</span>
      </div>
      <div class="stat down">
        <span class="stat-n mono">{sortedNews.filter(n => n.data.impact === 'negative').length}</span>
        <span class="stat-l">Bearish</span>
      </div>
      <div class="stat amber">
        <span class="stat-n mono">{sortedNews.filter(n => n.data.category === 'macro').length}</span>
        <span class="stat-l">Macro</span>
      </div>
      <div class="stat blue">
        <span class="stat-n mono">{sortedNews.filter(n => n.data.category === 'micro').length}</span>
        <span class="stat-l">Micro</span>
      </div>
      <div class="stat default">
        <span class="stat-n mono">{allTickers.length}</span>
        <span class="stat-l">Tickers</span>
      </div>
    </section>

    <!-- Filters -->
    <section class="filters">
      <div class="filter-row">
        <span class="filter-label">Category</span>
        <div class="btn-group">
          <button class="cat-btn active" data-cat="all">All</button>
          <button class="cat-btn" data-cat="macro">Macro</button>
          <button class="cat-btn" data-cat="micro">Micro</button>
        </div>
      </div>
      {allTickers.length > 0 && (
        <div class="filter-row">
          <span class="filter-label">Ticker</span>
          <div class="btn-group ticker-group">
            <button class="filter-btn active" data-filter="all">All</button>
            {allTickers.map(ticker => (
              <button class="filter-btn" data-filter={ticker}>{ticker}</button>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- News list -->
    <div id="news-list" data-news={JSON.stringify(sortedNews)}>
      {sortedNews.slice(0, ITEMS_PER_PAGE).map(news => (
        <a href={`/news/${news.id}`} class="card" data-tickers={(news.data.tickers || []).join(' ')} data-category={news.data.category}>
          <div class={`bar ${impactClass(news.data.impact ?? 'neutral')}`}></div>
          <div class="card-body">
            <div class="card-meta">
              <span class="mono dim">{formatDate(news.data.date)}</span>
              <span class="source">{news.data.source}</span>
              <span class={`impact-tag ${impactClass(news.data.impact ?? 'neutral')}`}>
                {news.data.impact === 'positive' ? '▲' : news.data.impact === 'negative' ? '▼' : '→'} {news.data.impact ?? 'neutral'}
              </span>
              <span class="tag">{news.data.category}</span>
              <span class="tag">{news.data.region}</span>
            </div>
            <h3 class="card-title">{news.data.title}</h3>
            {news.data.tickers && news.data.tickers.length > 0 && (
              <div class="chips">
                {news.data.tickers.map(t => <span class="chip">{t}</span>)}
              </div>
            )}
            <p class="preview">{news.body?.slice(0, 160).replace(/[#*\-_\[\]()\n]/g, ' ').trim()}…</p>
          </div>
          <span class="arrow">›</span>
        </a>
      ))}
    </div>

    <!-- Pagination -->
    {sortedNews.length > ITEMS_PER_PAGE && (
      <div class="pagination">
        <button id="prev-btn" disabled class="pg-btn">← Prev</button>
        <span id="page-info" class="mono dim">Page 1 of {totalPages}</span>
        <button id="next-btn" data-total={totalPages} class="pg-btn primary">Next →</button>
      </div>
    )}

  </div>

  <footer class="footer">
    Insider Hub &nbsp;·&nbsp; Built by Elesis &nbsp;·&nbsp; Auto-scraping active
  </footer>

</div>
</Layout>

<style>
  .page { min-height: 100vh; display: flex; flex-direction: column; }

  /* Topbar */
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 860px;
  }
  .topbar-left  { display: flex; align-items: center; gap: 0.75rem; }
  .topbar-right { display: flex; align-items: center; gap: 1rem; }
  .logo         { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .logo-sub     { font-size: 12px; color: var(--text-3); }
  .private-badge {
    font-size: 10px; font-weight: 500; color: var(--text-3);
    border: 1px solid var(--border); padding: 1px 6px; border-radius: 3px;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .dim  { font-size: 12px; color: var(--text-3); }
  .mono { font-family: var(--mono); }

  /* Body */
  .body { flex: 1; padding: 1.25rem 1.5rem; max-width: 860px; margin: 0 auto; width: 100%; }

  /* Stats */
  .stats-row {
    display: flex; gap: 1px; background: var(--border);
    border: 1px solid var(--border); margin-bottom: 1rem; overflow: hidden;
  }
  .stat {
    flex: 1; background: var(--bg); padding: 0.875rem 1rem;
    display: flex; flex-direction: column; gap: 0.2rem;
    transition: background 0.12s; cursor: default;
  }
  .stat:hover   { background: var(--bg-raised); }
  .stat-n       { font-size: 22px; font-weight: 500; line-height: 1; }
  .stat-l       { font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; }
  .stat.up    .stat-n { color: var(--up); }
  .stat.down  .stat-n { color: var(--down); }
  .stat.amber .stat-n { color: var(--amber); }
  .stat.blue  .stat-n { color: #2563eb; }
  .stat.default .stat-n { color: var(--text-2); }

  /* Filters */
  .filters {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding: 0.75rem 1rem; background: var(--bg-raised);
    border: 1px solid var(--border); margin-bottom: 1rem;
  }
  .filter-row   { display: flex; align-items: flex-start; gap: 0.75rem; }
  .filter-label {
    font-size: 11px; font-weight: 500; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.06em;
    padding-top: 4px; white-space: nowrap; min-width: 52px;
  }
  .btn-group    { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .ticker-group { max-height: 68px; overflow-y: auto; }

  .cat-btn, .filter-btn {
    font-size: 12px; font-family: var(--sans);
    padding: 3px 10px; border: 1px solid var(--border);
    background: var(--bg); color: var(--text-2);
    cursor: pointer; border-radius: 3px; transition: all 0.1s;
  }
  .cat-btn:hover,
  .filter-btn:hover   { background: var(--bg-subtle); color: var(--text); }
  .cat-btn.active     { background: var(--text); color: var(--bg); border-color: var(--text); }
  .filter-btn.active  { background: var(--up); color: #fff; border-color: var(--up); }

  /* Cards */
  #news-list { display: flex; flex-direction: column; }

  .card {
    display: flex; align-items: stretch;
    border-bottom: 1px solid var(--border-soft);
    transition: background 0.12s; cursor: pointer;
  }
  .card:first-child { border-top: 1px solid var(--border); }
  .card:hover { background: var(--bg-raised); }

  .bar { width: 3px; flex-shrink: 0; }
  .bar.up      { background: var(--up); }
  .bar.down    { background: var(--down); }
  .bar.neutral { background: var(--border); }

  .card-body { flex: 1; padding: 0.875rem 1rem; min-width: 0; }

  .card-meta {
    display: flex; align-items: center; gap: 0.5rem;
    flex-wrap: wrap; margin-bottom: 0.35rem;
  }
  .source { font-size: 11px; color: var(--amber); font-weight: 500; }

  .impact-tag {
    font-size: 10px; font-weight: 600;
    padding: 1px 6px; border-radius: 2px;
    text-transform: capitalize; letter-spacing: 0.02em;
  }
  .impact-tag.up      { color: var(--up);   background: var(--up-bg); }
  .impact-tag.down    { color: var(--down); background: var(--down-bg); }
  .impact-tag.neutral { color: var(--text-3); background: var(--bg-subtle); }

  .tag {
    font-size: 11px; color: var(--text-3);
    background: var(--bg-subtle); border: 1px solid var(--border-soft);
    padding: 1px 6px; border-radius: 2px; text-transform: capitalize;
  }

  .card-title {
    font-size: 15px; font-weight: 500; color: var(--text);
    line-height: 1.45; margin-bottom: 0.4rem; letter-spacing: -0.01em;
  }

  .chips { display: flex; gap: 0.3rem; flex-wrap: wrap; margin-bottom: 0.4rem; }
  .chip {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    color: var(--up); background: var(--up-bg);
    border: 1px solid rgba(26,110,60,0.18);
    padding: 1px 5px; border-radius: 2px;
  }

  .preview {
    font-size: 13px; color: var(--text-3); line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }

  .arrow { display: flex; align-items: center; padding: 0 1rem; color: var(--text-3); font-size: 18px; flex-shrink: 0; }

  /* Pagination */
  .pagination {
    display: flex; align-items: center; justify-content: center;
    gap: 1rem; padding: 1.25rem 0;
    border-top: 1px solid var(--border-soft); margin-top: 0.125rem;
  }
  .pg-btn {
    font-size: 13px; font-family: var(--sans);
    padding: 5px 14px; border: 1px solid var(--border);
    background: var(--bg); color: var(--text-2);
    cursor: pointer; border-radius: 3px; transition: all 0.1s;
  }
  .pg-btn:hover:not(:disabled) { background: var(--bg-subtle); color: var(--text); }
  .pg-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .pg-btn.primary  { background: var(--text); color: var(--bg); border-color: var(--text); }

  /* Footer */
  .footer {
    padding: 1rem 1.5rem; border-top: 1px solid var(--border);
    text-align: center; font-size: 12px; color: var(--text-3);
    background: var(--bg-subtle);
  }
</style>

<script>
  const PER_PAGE = 10;
  let page = 1, ticker = 'all', cat = 'all';

  const container = document.getElementById('news-list') as HTMLElement;
  const all: any[] = JSON.parse(container?.dataset.news || '[]');
  let items = all;

  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const pageInfo = document.getElementById('page-info') as HTMLElement;

  function cls(impact: string) {
    return impact === 'positive' ? 'up' : impact === 'negative' ? 'down' : 'neutral';
  }
  function arrow(impact: string) {
    return impact === 'positive' ? '▲' : impact === 'negative' ? '▼' : '→';
  }
  function fmt(dateStr: string) {
    const d = new Date(dateStr), now = new Date();
    const mins = Math.floor((now.getTime() - d.getTime()) / 60000);
    const hrs = Math.floor(mins / 60);
    if (mins < 60) return mins + 'm ago';
    if (hrs < 24) return hrs + 'h ago';
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
  }

  function makeCard(n: any) {
    const impact = n.data.impact ?? 'neutral';
    const tickers = n.data.tickers || [];
    const preview = (n.body || '').slice(0, 160).replace(/[#*\-_\[\]()\n]/g, ' ').trim() + '…';
    const a = document.createElement('a');
    a.href = '/news/' + n.id;
    a.className = 'card';
    a.innerHTML = `
      <div class="bar ${cls(impact)}"></div>
      <div class="card-body">
        <div class="card-meta">
          <span class="mono dim">${fmt(n.data.date)}</span>
          <span class="source">${n.data.source || ''}</span>
          <span class="impact-tag ${cls(impact)}">${arrow(impact)} ${impact}</span>
          <span class="tag">${n.data.category || ''}</span>
          <span class="tag">${n.data.region || ''}</span>
        </div>
        <h3 class="card-title">${n.data.title || ''}</h3>
        ${tickers.length ? `<div class="chips">${tickers.map((t: string) => `<span class="chip">${t}</span>`).join('')}</div>` : ''}
        <p class="preview">${preview}</p>
      </div>
      <span class="arrow">›</span>
    `;
    return a;
  }

  function render() {
    const start = (page - 1) * PER_PAGE;
    container.innerHTML = '';
    items.slice(start, start + PER_PAGE).forEach(n => container.appendChild(makeCard(n)));
    const pages = Math.ceil(items.length / PER_PAGE);
    if (pageInfo) pageInfo.textContent = `Page ${page} of ${pages} (${items.length} articles)`;
    if (prevBtn) prevBtn.disabled = page === 1;
    if (nextBtn) nextBtn.disabled = page >= pages;
  }

  function filter() {
    items = all.filter(n =>
      (cat === 'all' || n.data.category === cat) &&
      (ticker === 'all' || (n.data.tickers || []).includes(ticker))
    );
    page = 1;
  }

  function syncBtns() {
    document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.filter === ticker));
    document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(b => b.classList.toggle('active', b.dataset.cat === cat));
  }

  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(b =>
    b.addEventListener('click', () => { ticker = b.dataset.filter!; filter(); syncBtns(); render(); }));
  document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(b =>
    b.addEventListener('click', () => { cat = b.dataset.cat!; filter(); syncBtns(); render(); }));

  prevBtn?.addEventListener('click', () => { if (page > 1) { page--; render(); scrollTo(0, 0); } });
  nextBtn?.addEventListener('click', () => {
    if (page < Math.ceil(items.length / PER_PAGE)) { page++; render(); scrollTo(0, 0); }
  });
</script>
</Layout>
