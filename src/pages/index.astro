---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTickers = [...new Set(sortedNews.flatMap(n => n.data.tickers || []))].sort();
const ITEMS_PER_PAGE = 10;
const totalPages = Math.ceil(sortedNews.length / ITEMS_PER_PAGE);

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMins = Math.floor((now.getTime() - date.getTime()) / 60000);
  const diffHrs = Math.floor(diffMins / 60);
  if (diffMins < 60) return `${diffMins}m ago`;
  if (diffHrs < 24) return `${diffHrs}h ago`;
  return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}

function impactClass(impact: string) {
  if (impact === 'positive') return 'up';
  if (impact === 'negative') return 'down';
  return 'neutral';
}
---

<Layout title="Insider Hub — Indonesia Market Intelligence">
<div class="page">

  <!-- Top bar -->
  <header class="topbar">
    <div class="topbar-inner">
      <div class="topbar-left">
        <a href="/" class="logo">Insider Hub</a>
        <span class="logo-sub">Indonesia Market Intelligence</span>
        <span class="private-badge">Private</span>
      </div>
      <button class="mobile-menu-btn" aria-label="Menu" id="menuBtn">
        <span></span><span></span><span></span>
      </button>
      <nav class="topbar-nav" id="mainNav">
        <a href="/daily-summary" class="nav-link">Summary</a>
        <a href="/top-picks" class="nav-link">Top Picks</a>
        <a href="/portfolio" class="nav-link">Portfolio</a>
        <span class="nav-stats">
          <span class="mono dim">{sortedNews.length} articles</span>
          <span class="dim">Updated {formatDate(sortedNews[0]?.data.date || new Date().toISOString())}</span>
        </span>
      </nav>
    </div>
  </header>

  <div class="body">

    <!-- Stats -->
    <section class="stats-row">
      <div class="stat up">
        <span class="stat-n mono">{sortedNews.filter(n => n.data.impact === 'positive').length}</span>
        <span class="stat-l">Bullish</span>
      </div>
      <div class="stat down">
        <span class="stat-n mono">{sortedNews.filter(n => n.data.impact === 'negative').length}</span>
        <span class="stat-l">Bearish</span>
      </div>
      <div class="stat amber">
        <span class="stat-n mono">{sortedNews.filter(n => n.data.category === 'macro').length}</span>
        <span class="stat-l">Macro</span>
      </div>
      <div class="stat blue">
        <span class="stat-n mono">{sortedNews.filter(n => n.data.category === 'micro').length}</span>
        <span class="stat-l">Micro</span>
      </div>
      <div class="stat default">
        <span class="stat-n mono">{allTickers.length}</span>
        <span class="stat-l">Tickers</span>
      </div>
    </section>

    <!-- Commodities -->
    <section class="commodities">
      <div class="commodity comm-up">
        <span class="comm-name">Coal <span class="comm-sub">Newcastle</span></span>
        <span class="comm-tickers">ADRO · ITMG · PTBA</span>
        <div class="comm-right">
          <span class="mono comm-price">$128.50</span>
          <span class="mono up comm-delta">▲ +2.4%</span>
        </div>
      </div>
      <div class="commodity comm-down">
        <span class="comm-name">Nickel <span class="comm-sub">LME</span></span>
        <span class="comm-tickers">ANTM · INCO · NCKL</span>
        <div class="comm-right">
          <span class="mono comm-price">$16,200</span>
          <span class="mono down comm-delta">▼ −0.5%</span>
        </div>
      </div>
      <div class="commodity comm-up">
        <span class="comm-name">Palm Oil <span class="comm-sub">CPO</span></span>
        <span class="comm-tickers">AALI · LSIP · TAPG</span>
        <div class="comm-right">
          <span class="mono comm-price">RM 3,850</span>
          <span class="mono up comm-delta">▲ +0.8%</span>
        </div>
      </div>
      <div class="commodity comm-down">
        <span class="comm-name">IDR/USD</span>
        <span class="comm-tickers">Bank Indonesia</span>
        <div class="comm-right">
          <span class="mono comm-price">15,842</span>
          <span class="mono down comm-delta">▼ −0.3%</span>
        </div>
      </div>
      <div class="commodity comm-up">
        <span class="comm-name">Gold <span class="comm-sub">spot</span></span>
        <span class="comm-tickers">ANTM · global</span>
        <div class="comm-right">
          <span class="mono comm-price">$2,318</span>
          <span class="mono up comm-delta">▲ +0.6%</span>
        </div>
      </div>
    </section>

    <!-- BI Rate + Market Breadth -->
    <div class="two-col">

      <!-- BI Rate -->
      <section class="panel">
        <div class="panel-head">
          <span class="panel-title">BI Rate</span>
          <span class="panel-badge neutral-badge">Monetary Policy</span>
        </div>
        <div class="bi-body">
          <div class="bi-rate">
            <span class="mono bi-num">6.25%</span>
            <span class="bi-unchanged">unchanged</span>
          </div>
          <div class="bi-meta">
            <div class="bi-row">
              <span class="bi-label">Last decision</span>
              <span class="bi-val">19 Mar 2025 — Hold</span>
            </div>
            <div class="bi-row">
              <span class="bi-label">Next meeting</span>
              <span class="bi-val hi">23–24 Apr 2025</span>
            </div>
            <div class="bi-row">
              <span class="bi-label">Consensus</span>
              <span class="bi-val">Hold expected</span>
            </div>
            <div class="bi-row">
              <span class="bi-label">Rate vs equity</span>
              <span class="bi-val down">Negative pressure</span>
            </div>
          </div>
        </div>
        <div class="rate-history">
          <div class="rh-label">Rate history (12m)</div>
          <div class="rh-bars">
            {[5.75, 6.00, 6.00, 6.25, 6.25, 6.25, 6.25, 6.25, 6.25, 6.25, 6.25, 6.25].map((r, i) => (
              <div class="rh-bar-wrap" title={`${r}%`}>
                <div class="rh-bar" style={`height: ${((r - 5.5) / 1) * 100}%`}></div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Market Breadth -->
      <section class="panel">
        <div class="panel-head">
          <span class="panel-title">Market Breadth</span>
          <span class="panel-badge down-badge">Weak</span>
        </div>
        <div class="breadth-body">
          <div class="breadth-counts">
            <div class="bc up">
              <span class="mono bc-n">312</span>
              <span class="bc-l">Advancing</span>
            </div>
            <div class="bc down">
              <span class="mono bc-n">489</span>
              <span class="bc-l">Declining</span>
            </div>
            <div class="bc neutral-bc">
              <span class="mono bc-n">121</span>
              <span class="bc-l">Unchanged</span>
            </div>
          </div>
          <div class="breadth-bar-wrap">
            <div class="breadth-bar">
              <div class="bb-up" style="width: 34%"></div>
              <div class="bb-neutral" style="width: 13%"></div>
              <div class="bb-down" style="width: 53%"></div>
            </div>
            <div class="bb-labels">
              <span class="up">34%</span>
              <span class="down">53%</span>
            </div>
          </div>
          <div class="breadth-signal">
            <span class="signal-label">A/D Ratio</span>
            <span class="mono down signal-val">0.64 — more sellers than buyers</span>
          </div>
          <div class="breadth-signal">
            <span class="signal-label">52w High</span>
            <span class="mono signal-val">18 stocks</span>
          </div>
          <div class="breadth-signal">
            <span class="signal-label">52w Low</span>
            <span class="mono down signal-val">47 stocks</span>
          </div>
        </div>
      </section>
    </div>

    <!-- Foreign Flows -->
    <section class="panel flow-panel">
      <div class="panel-head">
        <span class="panel-title">Foreign Investor Net Flow</span>
        <span class="panel-badge down-badge">Net Sell</span>
        <span class="panel-note">IDX · Week of 31 Mar 2025</span>
      </div>
      <div class="flow-body">
        <div class="flow-summary">
          <div class="flow-main">
            <span class="mono flow-num down">−Rp 2.34T</span>
            <span class="flow-label">net sell this week</span>
          </div>
          <div class="flow-stats">
            <div class="fs-row">
              <span class="fs-label">Gross buy</span>
              <span class="mono fs-val up">Rp 8.12T</span>
            </div>
            <div class="fs-row">
              <span class="fs-label">Gross sell</span>
              <span class="mono fs-val down">Rp 10.46T</span>
            </div>
            <div class="fs-row">
              <span class="fs-label">YTD net</span>
              <span class="mono fs-val down">−Rp 18.7T</span>
            </div>
            <div class="fs-row">
              <span class="fs-label">Signal</span>
              <span class="fs-val down">Capital outflow — caution</span>
            </div>
          </div>
        </div>
        <div class="flow-chart">
          <div class="fc-label">4-week net flow (IDR Trillion)</div>
          <div class="fc-bars">
            {[
              { val: 1.2,  dir: 'up' },
              { val: -0.8, dir: 'down' },
              { val: -1.5, dir: 'down' },
              { val: -2.34,dir: 'down' },
            ].map(w => (
              <div class="fc-col">
                <div class="fc-bar-wrap">
                  <div class={`fc-bar ${w.dir}`} style={`height: ${Math.abs(w.val) / 2.5 * 100}%`}></div>
                </div>
                <span class={`mono fc-val ${w.dir}`}>{w.val > 0 ? '+' : ''}{w.val}T</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Sector Performance -->
    <section class="panel">
      <div class="panel-head">
        <span class="panel-title">Sector Performance</span>
        <span class="panel-note">IDX Sector Indices · YTD 2025</span>
      </div>
      <div class="sector-list">
        {[
          { name: 'Energy',       code: 'IDXENERGY',   ytd: +8.4,  mtd: +3.1,  stocks: ['ADRO','ITMG','PTBA'] },
          { name: 'Basic Mat.',   code: 'IDXBASIC',    ytd: +5.2,  mtd: +1.8,  stocks: ['ANTM','INCO','TINS'] },
          { name: 'Consumer',     code: 'IDXCYCLIC',   ytd: +2.1,  mtd: +0.4,  stocks: ['MAPI','ACES','ERAA'] },
          { name: 'Financials',   code: 'IDXFINANCE',  ytd: -1.3,  mtd: -0.9,  stocks: ['BBRI','BMRI','BBCA'] },
          { name: 'Industrials',  code: 'IDXINDUST',   ytd: -2.8,  mtd: -1.2,  stocks: ['ASII','SMGR','INTP'] },
          { name: 'Healthcare',   code: 'IDXHEALTH',   ytd: -3.5,  mtd: -2.1,  stocks: ['SIDO','KLBF','MIKA'] },
          { name: 'Technology',   code: 'IDXTECHNO',   ytd: -5.1,  mtd: -3.4,  stocks: ['GOTO','BUKA','EMTK'] },
          { name: 'Properties',   code: 'IDXPROPERT',  ytd: -6.7,  mtd: -2.8,  stocks: ['BSDE','CTRA','PWON'] },
        ].sort((a, b) => b.ytd - a.ytd).map(s => (
          <div class="sector-row">
            <div class="sector-left">
              <span class="sector-name">{s.name}</span>
              <span class="sector-code">{s.code}</span>
            </div>
            <div class="sector-tickers">
              {s.stocks.map(t => <span class="sticker">{t}</span>)}
            </div>
            <div class="sector-bars">
              <div class="sector-bar-wrap">
                <div class={`sector-bar ${s.ytd >= 0 ? 'up' : 'down'}`} style={`width: ${Math.min(Math.abs(s.ytd) / 10 * 100, 100)}%`}></div>
              </div>
            </div>
            <div class="sector-nums">
              <span class={`mono sector-ytd ${s.ytd >= 0 ? 'up' : 'down'}`}>{s.ytd > 0 ? '+' : ''}{s.ytd}%</span>
              <span class={`mono sector-mtd ${s.mtd >= 0 ? 'up' : 'down'}`}>{s.mtd > 0 ? '+' : ''}{s.mtd}%</span>
            </div>
            <div class="sector-period-labels">
              <span>YTD</span><span>MTD</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Filters -->
    <section class="filters">
      <div class="filter-row">
        <span class="filter-label">Category</span>
        <div class="btn-group">
          <button class="cat-btn active" data-cat="all">All</button>
          <button class="cat-btn" data-cat="macro">Macro</button>
          <button class="cat-btn" data-cat="micro">Micro</button>
        </div>
      </div>
      {allTickers.length > 0 && (
        <div class="filter-row">
          <span class="filter-label">Ticker</span>
          <div class="btn-group ticker-group">
            <button class="filter-btn active" data-filter="all">All</button>
            {allTickers.map(ticker => (
              <button class="filter-btn" data-filter={ticker}>{ticker}</button>
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- News list -->
    <div id="news-list" data-news={JSON.stringify(sortedNews)}>
      {sortedNews.slice(0, ITEMS_PER_PAGE).map(news => (
        <a href={`/news/${news.id}`} class="card" data-tickers={(news.data.tickers || []).join(' ')} data-category={news.data.category}>
          <div class={`bar ${impactClass(news.data.impact ?? 'neutral')}`}></div>
          <div class="card-body">
            <div class="card-meta">
              <span class="mono dim">{formatDate(news.data.date)}</span>
              <span class="source">{news.data.source}</span>
              <span class={`impact-tag ${impactClass(news.data.impact ?? 'neutral')}`}>
                {news.data.impact === 'positive' ? '▲' : news.data.impact === 'negative' ? '▼' : '→'} {news.data.impact ?? 'neutral'}
              </span>
              <span class="tag">{news.data.category}</span>
              <span class="tag">{news.data.region}</span>
            </div>
            <h3 class="card-title">{news.data.title}</h3>
            {news.data.tickers && news.data.tickers.length > 0 && (
              <div class="chips">
                {news.data.tickers.map(t => <span class="chip">{t}</span>)}
              </div>
            )}
            <p class="preview">{news.body?.slice(0, 160).replace(/[#*\-_\[\]()\n]/g, ' ').trim()}…</p>
          </div>
          <span class="arrow">›</span>
        </a>
      ))}
    </div>

    <!-- Pagination -->
    {sortedNews.length > ITEMS_PER_PAGE && (
      <div class="pagination">
        <button id="prev-btn" disabled class="pg-btn">← Prev</button>
        <span id="page-info" class="mono dim">Page 1 of {totalPages}</span>
        <button id="next-btn" data-total={totalPages} class="pg-btn primary">Next →</button>
      </div>
    )}

  </div>

  <footer class="footer">
    Insider Hub &nbsp;·&nbsp; Built by Elesis &nbsp;·&nbsp; Auto-scraping active
  </footer>

</div>
</Layout>

<style is:global>
  .page { min-height: 100vh; display: flex; flex-direction: column; }

  /* Topbar */
  .topbar {
    display: flex; align-items: center; justify-content: center;
    padding: 0 1.5rem; height: 48px;
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; background: var(--bg); z-index: 10;
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 860px;
  }
  .topbar-left  { display: flex; align-items: center; gap: 0.75rem; }
  .topbar-right { display: flex; align-items: center; gap: 1rem; }
  .logo         { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .logo-sub     { font-size: 12px; color: var(--text-3); }
  .private-badge {
    font-size: 10px; font-weight: 500; color: var(--text-3);
    border: 1px solid var(--border); padding: 1px 6px; border-radius: 3px;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .dim  { font-size: 12px; color: var(--text-3); }
  .mono { font-family: var(--mono); }
  .nav-link {
    font-size: 12px; color: var(--text-3); text-decoration: none;
    border: 1px solid var(--border); padding: 2px 8px; border-radius: 4px;
    transition: all 0.15s;
  }
  .nav-link:hover { color: var(--text-1); border-color: var(--accent-green); background: rgba(0, 208, 132, 0.1); }

  .topbar-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 32px;
    height: 32px;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    padding: 4px;
    gap: 3px;
    margin-left: auto;
  }
  .mobile-menu-btn span {
    display: block;
    width: 14px;
    height: 2px;
    background: var(--text-2);
    border-radius: 1px;
    transition: all 0.2s;
  }
  .mobile-menu-btn.open span:nth-child(1) { transform: rotate(45deg) translate(3px, 3px); }
  .mobile-menu-btn.open span:nth-child(2) { opacity: 0; }
  .mobile-menu-btn.open span:nth-child(3) { transform: rotate(-45deg) translate(4px, -4px); }

  .nav-stats {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-left: 0.75rem;
    padding-left: 0.75rem;
    border-left: 1px solid var(--border);
  }

  /* Body */
  .body { flex: 1; padding: 1.25rem 1.5rem; max-width: 860px; margin: 0 auto; width: 100%; }

  /* Stats */
  .stats-row {
    display: flex; gap: 1px; background: var(--border);
    border: 1px solid var(--border); margin-bottom: 1rem; overflow: hidden;
  }
  .stat {
    flex: 1; background: var(--bg); padding: 0.875rem 1rem;
    display: flex; flex-direction: column; gap: 0.2rem;
    transition: background 0.12s; cursor: default;
  }
  .stat:hover   { background: var(--bg-raised); }
  .stat-n       { font-size: 22px; font-weight: 500; line-height: 1; }
  .stat-l       { font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.06em; }
  .stat.up    .stat-n { color: var(--up); }
  .stat.down  .stat-n { color: var(--down); }
  .stat.amber .stat-n { color: var(--amber); }
  .stat.blue  .stat-n { color: #2563eb; }
  .stat.default .stat-n { color: var(--text-2); }

  /* Commodities */
  .commodities {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 1rem;
    overflow: hidden;
  }
  .commodity {
    background: var(--bg-raised);
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    transition: background 0.12s;
    border-top: 2px solid transparent;
  }
  .commodity:hover { background: var(--bg-subtle); }
  .comm-up      { border-top-color: var(--up);   background: var(--up-bg); }
  .comm-down    { border-top-color: var(--down);  background: var(--down-bg); }
  .comm-neutral { border-top-color: var(--border); }
  .comm-up:hover   { background: #e2f2e9; }
  .comm-down:hover { background: #fce8e8; }
  .comm-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
  }
  .comm-sub {
    font-size: 11px;
    font-weight: 400;
    color: var(--text-3);
    margin-left: 3px;
  }
  .comm-tickers {
    font-size: 11px;
    color: var(--text-3);
  }
  .comm-right {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
  .comm-price { font-size: 13px; color: var(--text); }
  .comm-delta { font-size: 12px; }

  /* Shared panel */
  .panel {
    border: 1px solid var(--border);
    background: var(--bg-raised);
    margin-bottom: 1rem;
    overflow: hidden;
  }
  .panel-head {
    display: flex; align-items: center; gap: 0.625rem;
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .panel-title { font-size: 12px; font-weight: 600; color: var(--text); text-transform: uppercase; letter-spacing: 0.06em; }
  .panel-note  { font-size: 11px; color: var(--text-3); margin-left: auto; }
  .panel-badge {
    font-size: 10px; font-weight: 600; padding: 1px 6px;
    border-radius: 2px; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .neutral-badge { color: var(--text-2); background: var(--bg-subtle); border: 1px solid var(--border); }
  .up-badge      { color: var(--up);   background: var(--up-bg); }
  .down-badge    { color: var(--down); background: var(--down-bg); }

  /* Two-col */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .two-col .panel { margin-bottom: 0; }

  /* BI Rate */
  .bi-body { display: flex; gap: 1.5rem; padding: 1rem; }
  .bi-rate { display: flex; align-items: baseline; gap: 0.625rem; margin-bottom: 0.75rem; }
  .bi-num  { font-size: 32px; font-weight: 500; color: var(--text); line-height: 1; }
  .bi-unchanged { font-size: 11px; color: var(--text-3); border: 1px solid var(--border); padding: 1px 6px; border-radius: 2px; }
  .bi-meta { display: flex; flex-direction: column; gap: 0.3rem; width: 100%; }
  .bi-body { flex-direction: column; }
  .bi-row  { display: flex; justify-content: space-between; font-size: 12px; }
  .bi-label { color: var(--text-3); }
  .bi-val  { color: var(--text); font-weight: 500; }
  .bi-val.hi { color: var(--amber); font-weight: 600; }

  .rate-history { padding: 0.75rem 1rem; border-top: 1px solid var(--border); }
  .rh-label { font-size: 11px; color: var(--text-3); margin-bottom: 0.375rem; }
  .rh-bars  { display: flex; align-items: flex-end; gap: 3px; height: 32px; }
  .rh-bar-wrap { flex: 1; height: 100%; display: flex; align-items: flex-end; }
  .rh-bar { width: 100%; background: var(--amber); opacity: 0.7; border-radius: 1px 1px 0 0; min-height: 3px; }

  /* Market Breadth */
  .breadth-body { padding: 1rem; }
  .breadth-counts { display: flex; gap: 1rem; margin-bottom: 0.875rem; }
  .bc { display: flex; flex-direction: column; gap: 0.15rem; }
  .bc-n { font-size: 20px; font-weight: 500; line-height: 1; }
  .bc-l { font-size: 11px; color: var(--text-3); }
  .bc.up   .bc-n { color: var(--up); }
  .bc.down .bc-n { color: var(--down); }
  .bc.neutral-bc .bc-n { color: var(--text-2); }

  .breadth-bar-wrap { margin-bottom: 0.75rem; }
  .breadth-bar { display: flex; height: 6px; border-radius: 3px; overflow: hidden; gap: 1px; }
  .bb-up      { background: var(--up); }
  .bb-neutral { background: var(--border); }
  .bb-down    { background: var(--down); }
  .bb-labels  { display: flex; justify-content: space-between; margin-top: 3px; font-size: 11px; }

  .breadth-signal { display: flex; justify-content: space-between; font-size: 12px; padding: 0.25rem 0; border-top: 1px solid var(--border-soft); }
  .signal-label { color: var(--text-3); }
  .signal-val   { color: var(--text); font-size: 11px; }

  /* Foreign Flows */
  .flow-panel .panel-head { flex-wrap: wrap; }
  .flow-body { display: grid; grid-template-columns: 1fr 200px; gap: 1rem; padding: 1rem; }
  .flow-summary { display: flex; flex-direction: column; gap: 0.75rem; }
  .flow-main { display: flex; flex-direction: column; gap: 0.2rem; }
  .flow-num  { font-size: 28px; font-weight: 500; line-height: 1; }
  .flow-label { font-size: 12px; color: var(--text-3); }
  .flow-stats { display: flex; flex-direction: column; gap: 0.3rem; }
  .fs-row  { display: flex; justify-content: space-between; font-size: 12px; }
  .fs-label { color: var(--text-3); }
  .fs-val  { font-weight: 500; }

  .flow-chart { display: flex; flex-direction: column; gap: 0.5rem; }
  .fc-label  { font-size: 11px; color: var(--text-3); }
  .fc-bars   { display: flex; gap: 0.5rem; align-items: flex-end; height: 80px; }
  .fc-col    { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 0.25rem; height: 100%; justify-content: flex-end; }
  .fc-bar-wrap { flex: 1; width: 100%; display: flex; align-items: flex-end; }
  .fc-bar    { width: 100%; border-radius: 2px 2px 0 0; min-height: 4px; }
  .fc-bar.up   { background: var(--up); }
  .fc-bar.down { background: var(--down); }
  .fc-val    { font-size: 10px; }

  /* Sector Performance */
  .sector-list { display: flex; flex-direction: column; }
  .sector-row {
    display: grid;
    grid-template-columns: 140px 1fr 120px 64px 40px;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--border-soft);
    transition: background 0.12s;
  }
  .sector-row:last-child { border-bottom: none; }
  .sector-row:hover { background: var(--bg-subtle); }
  .sector-left { display: flex; flex-direction: column; gap: 0.1rem; }
  .sector-name { font-size: 13px; font-weight: 500; color: var(--text); }
  .sector-code { font-size: 10px; color: var(--text-3); font-family: var(--mono); }
  .sector-tickers { display: flex; gap: 0.25rem; flex-wrap: wrap; }
  .sticker {
    font-size: 10px; font-family: var(--mono); color: var(--text-2);
    background: var(--bg-subtle); border: 1px solid var(--border-soft);
    padding: 0 4px; border-radius: 2px;
  }
  .sector-bars { display: flex; align-items: center; }
  .sector-bar-wrap { width: 100%; height: 6px; background: var(--bg-subtle); border-radius: 3px; overflow: hidden; }
  .sector-bar { height: 100%; border-radius: 3px; }
  .sector-bar.up   { background: var(--up); }
  .sector-bar.down { background: var(--down); }
  .sector-nums { display: flex; flex-direction: column; gap: 0.1rem; align-items: flex-end; }
  .sector-ytd { font-size: 13px; font-weight: 600; }
  .sector-mtd { font-size: 11px; }
  .sector-period-labels { display: flex; flex-direction: column; gap: 0.1rem; font-size: 10px; color: var(--text-3); }

  /* Color utilities */
  .up     { color: var(--up); }
  .down   { color: var(--down); }
  .amber  { color: var(--amber); }

  /* Filters */
  .filters {
    display: flex; flex-direction: column; gap: 0.5rem;
    padding: 0.75rem 1rem; background: var(--bg-raised);
    border: 1px solid var(--border); margin-bottom: 1rem;
  }
  .filter-row   { display: flex; align-items: flex-start; gap: 0.75rem; }
  .filter-label {
    font-size: 11px; font-weight: 500; color: var(--text-3);
    text-transform: uppercase; letter-spacing: 0.06em;
    padding-top: 4px; white-space: nowrap; min-width: 52px;
  }
  .btn-group    { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .ticker-group { max-height: 68px; overflow-y: auto; }

  .cat-btn, .filter-btn {
    font-size: 12px; font-family: var(--sans);
    padding: 3px 10px; border: 1px solid var(--border);
    background: var(--bg); color: var(--text-2);
    cursor: pointer; border-radius: 3px; transition: all 0.1s;
  }
  .cat-btn:hover,
  .filter-btn:hover   { background: var(--bg-subtle); color: var(--text); }
  .cat-btn.active     { background: var(--text); color: var(--bg); border-color: var(--text); }
  .filter-btn.active  { background: var(--up); color: #fff; border-color: var(--up); }

  /* Cards */
  #news-list { display: flex; flex-direction: column; }

  .card {
    display: flex; align-items: stretch;
    border-bottom: 1px solid var(--border-soft);
    transition: background 0.12s; cursor: pointer;
  }
  .card:first-child { border-top: 1px solid var(--border); }
  .card:hover { background: var(--bg-raised); }

  .bar { width: 3px; flex-shrink: 0; }
  .bar.up      { background: var(--up); }
  .bar.down    { background: var(--down); }
  .bar.neutral { background: var(--border); }

  .card-body { flex: 1; padding: 0.875rem 1rem; min-width: 0; }

  .card-meta {
    display: flex; align-items: center; gap: 0.5rem;
    flex-wrap: wrap; margin-bottom: 0.35rem;
  }
  .source { font-size: 11px; color: var(--amber); font-weight: 500; }

  .impact-tag {
    font-size: 10px; font-weight: 600;
    padding: 1px 6px; border-radius: 2px;
    text-transform: capitalize; letter-spacing: 0.02em;
  }
  .impact-tag.up      { color: var(--up);   background: var(--up-bg); }
  .impact-tag.down    { color: var(--down); background: var(--down-bg); }
  .impact-tag.neutral { color: var(--text-3); background: var(--bg-subtle); }

  .tag {
    font-size: 11px; color: var(--text-3);
    background: var(--bg-subtle); border: 1px solid var(--border-soft);
    padding: 1px 6px; border-radius: 2px; text-transform: capitalize;
  }

  .card-title {
    font-size: 15px; font-weight: 500; color: var(--text);
    line-height: 1.45; margin-bottom: 0.4rem; letter-spacing: -0.01em;
  }

  .chips { display: flex; gap: 0.3rem; flex-wrap: wrap; margin-bottom: 0.4rem; }
  .chip {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    color: var(--up); background: var(--up-bg);
    border: 1px solid rgba(26,110,60,0.18);
    padding: 1px 5px; border-radius: 2px;
  }

  .preview {
    font-size: 13px; color: var(--text-3); line-height: 1.55;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }

  .arrow { display: flex; align-items: center; padding: 0 1rem; color: var(--text-3); font-size: 18px; flex-shrink: 0; }

  /* Pagination */
  .pagination {
    display: flex; align-items: center; justify-content: center;
    gap: 1rem; padding: 1.25rem 0;
    border-top: 1px solid var(--border-soft); margin-top: 0.125rem;
  }
  .pg-btn {
    font-size: 13px; font-family: var(--sans);
    padding: 5px 14px; border: 1px solid var(--border);
    background: var(--bg); color: var(--text-2);
    cursor: pointer; border-radius: 3px; transition: all 0.1s;
  }
  .pg-btn:hover:not(:disabled) { background: var(--bg-subtle); color: var(--text); }
  .pg-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .pg-btn.primary  { background: var(--text); color: var(--bg); border-color: var(--text); }

  /* Footer */
  .footer {
    padding: 1rem 1.5rem; border-top: 1px solid var(--border);
    text-align: center; font-size: 12px; color: var(--text-3);
    background: var(--bg-subtle);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .topbar { height: auto; }
    .topbar-inner { 
      flex-wrap: wrap; 
      padding: 0.5rem 0.75rem;
      position: relative;
    }
    .mobile-menu-btn { display: flex; }
    .topbar-nav { 
      display: none; 
      width: 100%; 
      flex-direction: column;
      gap: 0.25rem;
      padding-top: 0.5rem;
      margin-top: 0.5rem;
      border-top: 1px solid var(--border);
    }
    .topbar-nav.open { display: flex; }
    .nav-link { 
      font-size: 13px; 
      padding: 0.5rem 0.25rem;
      border: none;
      border-radius: 0;
      border-bottom: 1px solid var(--border-soft);
    }
    .nav-link:last-of-type { border-bottom: none; }
    .nav-stats { display: none; }
    .logo { font-size: 16px; }
    .logo-sub { display: none; }
    .private-badge { font-size: 9px; padding: 1px 4px; }
  }

  @media (max-width: 640px) {
    .body { padding: 0.75rem; }
    
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .stat { padding: 0.625rem; }
    .stat-n { font-size: 18px; }
    
    .commodities { grid-template-columns: repeat(2, 1fr); }
    .commodity { padding: 0.5rem; }
    .comm-name { font-size: 12px; }
    .comm-price { font-size: 11px; }
    
    .two-col { grid-template-columns: 1fr; }
    
    .flow-body { grid-template-columns: 1fr; }
    .fc-bars { height: 60px; }
    
    .sector-row {
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
      padding: 0.5rem;
    }
    .sector-tickers, .sector-bars, .sector-nums, .sector-period-labels { display: none; }
    
    .filters { padding: 0.5rem; }
    .btn-group { gap: 0.25rem; }
    .cat-btn, .filter-btn { font-size: 11px; padding: 2px 6px; }
    
    .card { padding: 0.5rem; }
    .card-title { font-size: 14px; }
    .preview { font-size: 12px; -webkit-line-clamp: 1; }
    .chips { display: none; }
    
    .pagination { gap: 0.5rem; padding: 1rem 0; }
    .pg-btn { font-size: 12px; padding: 4px 10px; }
  }

  @media (max-width: 480px) {
    .commodities { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: 1fr; }
    .stat { flex-direction: row; justify-content: space-between; align-items: center; }
    .stat-l { font-size: 11px; }
    
    .private-badge { display: none; }
  }
</style>

<script>
  const PER_PAGE = 10;
  let page = 1, ticker = 'all', cat = 'all';

  const container = document.getElementById('news-list') as HTMLElement;
  const all: any[] = JSON.parse(container?.dataset.news || '[]');
  let items = all;

  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const pageInfo = document.getElementById('page-info') as HTMLElement;

  function cls(impact: string) {
    return impact === 'positive' ? 'up' : impact === 'negative' ? 'down' : 'neutral';
  }
  function arrow(impact: string) {
    return impact === 'positive' ? '▲' : impact === 'negative' ? '▼' : '→';
  }
  function fmt(dateStr: string) {
    const d = new Date(dateStr), now = new Date();
    const mins = Math.floor((now.getTime() - d.getTime()) / 60000);
    const hrs = Math.floor(mins / 60);
    if (mins < 60) return mins + 'm ago';
    if (hrs < 24) return hrs + 'h ago';
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
  }

  function makeCard(n: any) {
    const impact = n.data.impact ?? 'neutral';
    const tickers = n.data.tickers || [];
    const preview = (n.body || '').slice(0, 160).replace(/[#*\-_\[\]()\n]/g, ' ').trim() + '…';
    const a = document.createElement('a');
    a.href = '/news/' + n.id;
    a.className = 'card';
    a.innerHTML = `
      <div class="bar ${cls(impact)}"></div>
      <div class="card-body">
        <div class="card-meta">
          <span class="mono dim">${fmt(n.data.date)}</span>
          <span class="source">${n.data.source || ''}</span>
          <span class="impact-tag ${cls(impact)}">${arrow(impact)} ${impact}</span>
          <span class="tag">${n.data.category || ''}</span>
          <span class="tag">${n.data.region || ''}</span>
        </div>
        <h3 class="card-title">${n.data.title || ''}</h3>
        ${tickers.length ? `<div class="chips">${tickers.map((t: string) => `<span class="chip">${t}</span>`).join('')}</div>` : ''}
        <p class="preview">${preview}</p>
      </div>
      <span class="arrow">›</span>
    `;
    return a;
  }

  function render() {
    const start = (page - 1) * PER_PAGE;
    container.innerHTML = '';
    items.slice(start, start + PER_PAGE).forEach(n => container.appendChild(makeCard(n)));
    const pages = Math.ceil(items.length / PER_PAGE);
    if (pageInfo) pageInfo.textContent = `Page ${page} of ${pages} (${items.length} articles)`;
    if (prevBtn) prevBtn.disabled = page === 1;
    if (nextBtn) nextBtn.disabled = page >= pages;
  }

  function filter() {
    items = all.filter(n =>
      (cat === 'all' || n.data.category === cat) &&
      (ticker === 'all' || (n.data.tickers || []).includes(ticker))
    );
    page = 1;
  }

  function syncBtns() {
    document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.filter === ticker));
    document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(b => b.classList.toggle('active', b.dataset.cat === cat));
  }

  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(b =>
    b.addEventListener('click', () => { ticker = b.dataset.filter!; filter(); syncBtns(); render(); }));
  document.querySelectorAll<HTMLButtonElement>('.cat-btn').forEach(b =>
    b.addEventListener('click', () => { cat = b.dataset.cat!; filter(); syncBtns(); render(); }));

  prevBtn?.addEventListener('click', () => { if (page > 1) { page--; render(); scrollTo(0, 0); } });
  nextBtn?.addEventListener('click', () => {
    if (page < Math.ceil(items.length / PER_PAGE)) { page++; render(); scrollTo(0, 0); }
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('menuBtn') as HTMLButtonElement;
  const mainNav = document.getElementById('mainNav') as HTMLElement;
  menuBtn?.addEventListener('click', () => {
    menuBtn.classList.toggle('open');
    mainNav?.classList.toggle('open');
  });
</script>
</Layout>
